# ── Build stage ───────────────────────────────────────────────────────────────
# Builds the React/Vite app from source so all TSX changes (incl. ContactSection)
# are reflected on every Railway deploy — no manual local build required.
FROM node:20-alpine AS builder
WORKDIR /build
COPY lovable_website_version/package*.json ./
RUN npm ci --prefer-offline
COPY lovable_website_version/ ./
RUN npm run build

# ── Serve stage ───────────────────────────────────────────────────────────────
FROM nginx:alpine
COPY --from=builder /build/dist/ /usr/share/nginx/html/
# Overwrite Vite's hashed logo file with the latest source asset so
# a changed logo.png is always served — Vite content-hashes handle cache busting.
COPY lovable_website_version/src/assets/logo.png /usr/share/nginx/html/assets/bridge-logo.png
COPY nginx-website2.conf /etc/nginx/conf.d/default.conf.template
EXPOSE 8080
CMD ["/bin/sh", "-c", "envsubst '$PORT' < /etc/nginx/conf.d/default.conf.template > /etc/nginx/conf.d/default.conf && exec nginx -g 'daemon off;'"]
