FROM python:3.12-slim

WORKDIR /app

# ── System packages (lean — no CLI tools, no mobile build stack) ──────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    nginx \
    supervisor \
    git \
    curl \
    gnupg \
    ca-certificates \
    gettext-base \
    openssh-client \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# ── GitHub CLI (gh) ───────────────────────────────────────────────────────────
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        -o /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update \
    && apt-get install -y gh \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# ── Railway CLI ───────────────────────────────────────────────────────────────
RUN npm install -g @railway/cli

# NO: code-server, Claude Code CLI, Gemini CLI, Flutter, Android SDK, Java JDK
# Those live exclusively in the cli-worker service.

# ── Python dependencies ───────────────────────────────────────────────────────
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# ── Application source ────────────────────────────────────────────────────────
COPY . .

# ── Config files ──────────────────────────────────────────────────────────────
COPY supervisord.api.conf /etc/supervisor/conf.d/supervisord.conf
COPY nginx.conf.template /app/nginx.conf.template

# ── Workspace dir (for session files / SQLite fallback) ───────────────────────
RUN mkdir -p /workspace /var/log/supervisor

# ── Entrypoint ────────────────────────────────────────────────────────────────
COPY entrypoint.api.sh /app/entrypoint.api.sh
RUN sed -i 's/\r//' /app/entrypoint.api.sh && chmod +x /app/entrypoint.api.sh

EXPOSE 8000

CMD ["/app/entrypoint.api.sh"]
