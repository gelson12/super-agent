# --- LLM API Keys ---
ANTHROPIC_API_KEY=your_anthropic_key_here
GEMINI_API_KEY=your_gemini_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here

# --- Cost guardrails (max tokens per call) ---
MAX_TOKENS_CLAUDE=1200
MAX_TOKENS_GEMINI=2048
MAX_TOKENS_DEEPSEEK=2048

# --- Per-model budget alerts (USD) — set 0 to disable ---
BUDGET_CLAUDE_USD=5.0
BUDGET_GEMINI_USD=5.0
BUDGET_DEEPSEEK_USD=5.0

# --- Video / Media Storage (Cloudinary) ---
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_CLOUD_NAME=your_cloud_name

# --- LangSmith observability (optional but recommended) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=super-agent
