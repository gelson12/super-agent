          "name": "postgres"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO audit_logs (entity_type, entity_id, action, performed_by, details, created_at) VALUES ('gmail_message', $1, $2, 'auto_compose', $3::jsonb, NOW())",
        "options": {
          "queryParams": "={{ $json.message_id || $json.id || '' }},={{ $json.compose_action || 'compose' }},={{ JSON.stringify({ to: $json.to_address || $json.sendTo || '', subject: $json.subject || '', source: 'compose_workflow' }) }}"
