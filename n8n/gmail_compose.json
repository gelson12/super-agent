        "options": {
          "queryParams": "={{ $json.id || '' }},={{ $json.message?.id || '' }},={{ $json.to_address || $json.sendTo || '' }},={{ $json.subject || '' }},={{ ($json.body || $json.message || '').substring(0, 200) }},={{ $json.correlation_id || '00000000-0000-0000-0000-000000000000' }}"
        }
      },
      "id": "comp-logdraft-001",
      "name": "Log Draft",
      "type": "n8n-nodes-base.postgres",
