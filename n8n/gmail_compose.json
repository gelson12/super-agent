    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO gmail_sends (message_id, original_message_id, to_address, subject, compose_action, correlation_id, sent_at) VALUES ($1, $2, $3, $4, $5, $6::uuid, NOW())",
        "options": {
          "queryParams": "={{ $json.id || $json.message_id || '' }},={{ $json.original_message_id || '' }},={{ $json.to_address || $json.sendTo || '' }},={{ $json.subject || '' }},={{ $json.compose_action || 'send' }},={{ $json.correlation_id || '00000000-0000-0000-0000-000000000000' }}"
        }
      },
