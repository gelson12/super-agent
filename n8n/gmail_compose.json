      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id FROM gmail_sends WHERE to_address = $1 AND subject = $2 AND sent_at > NOW() - INTERVAL '5 minutes' LIMIT 1",
        "options": {
          "queryParams": "={{ $json.to_address || $json.sendTo }},={{ $json.subject }}"
        }
      },
      "id": "comp-checkdup-001",
