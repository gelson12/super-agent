      "name": "Log Execution",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [2160, 400],
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO workflow_runs (correlation_id, workflow_name, trigger_type, trigger_source, status, started_at, finished_at, execution_id) VALUES ($1::uuid, $2, $3, $4, 'success', $5::timestamptz, NOW(), $6)",
        "options": {
          "queryParameters": "={{ $json.correlation_id }},Gmail-Admin-Orchestrator,={{ $json.trigger_type }},={{ $json.trigger_source }},={{ $json.timestamp }},={{ $execution.id }}"
        }
      },
      "credentials": {
