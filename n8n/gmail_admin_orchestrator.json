{
  "name": "Gmail-Admin-Orchestrator",
  "nodes": [
    {
      "id": "gmail-trigger",
      "name": "New Email Trigger",
      "type": "n8n-nodes-base.gmailTrigger",
      "typeVersion": 1.2,
      "position": [240, 300],
      "parameters": {
        "pollTimes": {
          "item": [
            {
              "mode": "everyMinute"
            }
          ]
        },
        "simple": false,
        "filters": {
          "q": "-from:(property-alerts@mail.onthemarket.com) -from:(rightmove.co.uk) -from:(zoopla.co.uk) -from:(spareroom.co.uk) -from:(openrent.co.uk) -from:(primelocation.com) -from:(iroomit.com)"
        },
        "options": {}
      },
      "credentials": {
        "gmailOAuth2": {
          "id": "RECONNECT",
          "name": "Gmail account"
        }
      }
    },
    {
      "id": "cron-trigger",
      "name": "Digest Schedule",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [240, 520],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 8 * * *"
            },
            {
              "field": "cronExpression",
              "expression": "0 12 * * *"
            },
            {
              "field": "cronExpression",
              "expression": "0 21 * * *"
            }
          ]
        }
      }
    },
    {
      "id": "webhook-trigger",
      "name": "API Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 740],
      "parameters": {
        "httpMethod": "POST",
        "path": "gmail-admin",
        "responseMode": "lastNode",
        "options": {}
      },
      "webhookId": "gmail-admin"
    },
    {
      "id": "normalize",
      "name": "Normalize Trigger Data",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [480, 520],
      "parameters": {
        "mode": "manual",
        "duplicateItem": false,
        "assignments": {
          "assignments": [
            {
              "id": "trigger_type",
              "name": "trigger_type",
              "value": "={{ $input.first().json.id ? 'realtime' : ($input.first().json.body ? 'webhook' : 'scheduled') }}",
              "type": "string"
            },
            {
              "id": "trigger_source",
              "name": "trigger_source",
              "value": "={{ $input.first().json.id ? 'gmail_trigger' : ($input.first().json.body ? 'webhook' : 'schedule_trigger') }}",
              "type": "string"
            },
            {
              "id": "timestamp",
              "name": "timestamp",
              "value": "={{ $now.toISO() }}",
              "type": "string"
            },
            {
              "id": "correlation_id",
              "name": "correlation_id",
              "value": "={{ $json.correlation_id || $now.toMillis().toString(36) + Math.random().toString(36).substr(2, 5) }}",
              "type": "string"
            },
            {
              "id": "payload",
              "name": "payload",
              "value": "={{ JSON.stringify($json) }}",
              "type": "string"
            }
          ]
        },
        "includeOtherFields": true,
        "options": {}
      }
    },
    {
      "id": "property-filter",
      "name": "Filter Property Alerts",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [600, 100],
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst sender = (item.sender || item.from || '').toLowerCase();\nconst subject = (item.subject || '').toLowerCase();\nconst snippet = (item.snippet || '').toLowerCase();\n\n// Block known property listing senders\nconst blockedSenders = [\n  'property-alerts@mail.onthemarket.com',\n  'rightmove.co.uk',\n  'zoopla.co.uk',\n  'spareroom.co.uk',\n  'openrent.co.uk',\n  'primelocation.com',\n  'iroomit.com'\n];\n\nconst isBlockedSender = blockedSenders.some(s => sender.includes(s));\n\n// Block messages that look like property listings\nconst propertyKeywords = ['house shares', 'flat shares', 'rooms to rent', 'properties to rent', 'new to market', 'reduced'];\nconst isPropertyMsg = propertyKeywords.some(kw => subject.includes(kw) || snippet.includes(kw));\n\nif (isBlockedSender || isPropertyMsg) {\n  // Return empty — this item is filtered out\n  return [];\n}\n\nreturn [{ json: item, binary: $input.first().binary || {} }];"
      }
    },
    {
      "id": "route-switch",
      "name": "Route by Trigger Type",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [720, 520],
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": { "caseSensitive": true, "typeValidation": "strict" },
                "combinator": "and",
                "conditions": [
                  {
                    "id": "realtime-condition",
                    "leftValue": "={{ $json.trigger_type }}",
                    "rightValue": "realtime",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "Realtime Email"
            },
            {
              "conditions": {
                "options": { "caseSensitive": true, "typeValidation": "strict" },
                "combinator": "and",
                "conditions": [
                  {
                    "id": "scheduled-condition",
                    "leftValue": "={{ $json.trigger_type }}",
                    "rightValue": "scheduled",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "Scheduled Digest"
            },
            {
              "conditions": {
                "options": { "caseSensitive": true, "typeValidation": "strict" },
                "combinator": "and",
                "conditions": [
                  {
                    "id": "webhook-condition",
                    "leftValue": "={{ $json.trigger_type }}",
                    "rightValue": "webhook",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "Webhook Command"
            }
          ]
        },
        "fallbackOutput": "extra",
        "options": {}
      }
    },
    {
      "id": "exec-intake",
      "name": "Execute Intake",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.2,
      "position": [960, 300],
      "parameters": {
        "workflowId": { "__rl": true, "value": "", "mode": "id" },
        "waitForSubWorkflow": true,
        "options": {}
      }
    },
    {
