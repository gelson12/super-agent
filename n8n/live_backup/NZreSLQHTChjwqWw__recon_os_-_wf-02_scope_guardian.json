                  },
                  {
                      "parameters":  {
                                         "operation":  "executeQuery",
                                         "query":  "SELECT id, status, testing_window_start, testing_window_end, rate_limit_profile\nFROM engagements\nWHERE id = \u0027{{ $json.engagement_id }}\u0027\nLIMIT 1;",
                                         "options":  {

                                                     }
                                     },
                      "id":  "pg-get-engagement",
                      "name":  "Get Engagement",
                      "type":  "n8n-nodes-base.postgres",
                      "typeVersion":  2.5,
                      "position":  [
                                       460,
                                       300
                                   ],
                      "credentials":  {
                                          "postgres":  {
                                                           "id":  "oHS3dvjMW1h1PkMp",
                                                           "name":  "RECON OS PostgreSQL"
                                                       }
                                      }
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const eng = $input.first().json;\nconst asset = $(\u0027Execute Workflow Trigger\u0027).first().json.asset_value || \u0027\u0027;\nif (!eng || !eng.id) {\n  return [{ json: { allowed: false, reason: \u0027engagement_not_found\u0027, asset_value: asset } }];\n}\nif (eng.status !== \u0027active\u0027) {\n  return [{ json: { allowed: false, reason: \u0027engagement_not_active\u0027, status: eng.status, asset_value: asset } }];\n}\nconst now = new Date();\nconst start = new Date(eng.testing_window_start);\nconst end = new Date(eng.testing_window_end);\nif (now \u003c start || now \u003e end) {\n  return [{ json: { allowed: false, reason: \u0027outside_testing_window\u0027, window_start: eng.testing_window_start, window_end: eng.testing_window_end, asset_value: asset } }];\n}\nreturn [{ json: { engagement_ok: true, engagement_id: eng.id, rate_limit_profile: eng.rate_limit_profile, asset_value: asset } }];"
                                     },
                      "id":  "check-engagement",
                      "name":  "Check Engagement Status",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       680,
                                       300
                                   ]
                  },
                  {
                      "parameters":  {
                                         "conditions":  {
                                                            "options":  {
                                                                            "caseSensitive":  true,
                                                                            "leftValue":  "",
                                                                            "typeValidation":  "strict"
                                                                        },
                                                            "conditions":  [
                                                                               {
                                                                                   "id":  "cond-eng",
