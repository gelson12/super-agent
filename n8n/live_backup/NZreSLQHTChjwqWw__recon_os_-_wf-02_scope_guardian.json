                                     },
                      "id":  "if-eng-ok",
                      "name":  "IF Engagement OK?",
                      "type":  "n8n-nodes-base.if",
                      "typeVersion":  2.2,
                      "position":  [
                                       900,
                                       300
                                   ]
                  },
                  {
                      "parameters":  {
                                         "operation":  "executeQuery",
                                         "query":  "SELECT id, value, scope_type, in_scope\nFROM scope_rules\nWHERE engagement_id = \u0027{{ $json.engagement_id }}\u0027\nAND in_scope = true;",
                                         "options":  {

                                                     }
                                     },
                      "id":  "pg-get-scope",
                      "name":  "Get Scope Rules",
                      "type":  "n8n-nodes-base.postgres",
                      "typeVersion":  2.5,
                      "position":  [
                                       1120,
                                       300
                                   ],
                      "credentials":  {
                                          "postgres":  {
                                                           "id":  "oHS3dvjMW1h1PkMp",
                                                           "name":  "RECON OS PostgreSQL"
                                                       }
                                      }
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const rules = $input.all().map(i =\u003e i.json);\nconst triggerData = $(\u0027Execute Workflow Trigger\u0027).first().json;\nconst assetValue = (triggerData.asset_value || \u0027\u0027).toLowerCase().trim().replace(/\\.$/,\u0027\u0027);\nconst engId = $(\u0027Check Engagement Status\u0027).first().json.engagement_id;\nconst rateProfile = $(\u0027Check Engagement Status\u0027).first().json.rate_limit_profile;\n\nfunction normalizeHost(h) {\n  return h.toLowerCase().trim().replace(/\\.$/,\u0027\u0027).replace(/^https?:\\/\\//,\u0027\u0027).split(\u0027/\u0027)[0];\n}\n\nlet matched = null;\nfor (const rule of rules) {\n  const ruleVal = normalizeHost(rule.value);\n  if (rule.scope_type === \u0027domain\u0027 || rule.scope_type === \u0027web_app\u0027 || rule.scope_type === \u0027api\u0027) {\n    if (assetValue === ruleVal) { matched = rule; break; }\n  } else if (rule.scope_type === \u0027subdomain_wildcard\u0027) {\n    const base = ruleVal.replace(/^\\*\\./, \u0027\u0027);\n    if (assetValue === base || assetValue.endsWith(\u0027.\u0027 + base)) { matched = rule; break; }\n  } else if (rule.scope_type === \u0027ip\u0027) {\n    if (assetValue === ruleVal) { matched = rule; break; }\n  } else if (rule.scope_type === \u0027cidr\u0027) {\n    // Basic CIDR check - for production use a proper CIDR library\n    const [network, bits] = ruleVal.split(\u0027/\u0027);\n    matched = null; // placeholder - analyst should verify IP scope manually\n  } else if (rule.scope_type === \u0027environment\u0027) {\n    if (assetValue.includes(ruleVal)) { matched = rule; break; }\n  }\n}\n\nif (!matched) {\n  return [{ json: { allowed: false, reason: \u0027out_of_scope\u0027, asset_value: assetValue, engagement_id: engId } }];\n}\n\nreturn [{ json: { allowed: true, scope_rule_id: matched.id, scope_type: matched.scope_type, asset_value: assetValue, engagement_id: engId, rate_limit_profile: rateProfile } }];"
                                     },
                      "id":  "check-scope",
                      "name":  "Check Asset Scope",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
