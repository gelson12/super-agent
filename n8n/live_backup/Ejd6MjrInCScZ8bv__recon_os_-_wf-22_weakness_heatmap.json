                      "id":  "wh-heatmap",
                      "name":  "Webhook",
                      "type":  "n8n-nodes-base.webhook",
                      "typeVersion":  2,
                      "position":  [
                                       240,
                                       500
                                   ],
                      "webhookId":  "recon-os-internal-heatmap"
                  },
                  {
                      "parameters":  {
                                         "operation":  "executeQuery",
                                         "query":  "SELECT\n  c.id as client_id,\n  c.name as client_name,\n  nf.category,\n  nf.cwe_id,\n  nf.owasp_category,\n  COUNT(nf.id) as occurrence_count,\n  COUNT(DISTINCT nf.engagement_id) as engagement_count,\n  MIN(nf.first_seen) as first_seen,\n  MAX(nf.last_seen) as last_seen,\n  AVG(nf.recon_score) as avg_score,\n  COUNT(nf.id) FILTER (WHERE nf.remediation_status = \u0027verified_fixed\u0027) as times_fixed,\n  COUNT(nf.id) FILTER (WHERE nf.reopen_count \u003e 0) as times_reopened\nFROM normalized_findings nf\nJOIN engagements e ON nf.engagement_id = e.id\nJOIN clients c ON e.client_id = c.id\nWHERE nf.validation_status IN (\u0027validated\u0027,\u0027analyst_reviewed\u0027,\u0027verified_fixed\u0027)\n  AND nf.cwe_id IS NOT NULL\nGROUP BY c.id, c.name, nf.category, nf.cwe_id, nf.owasp_category\nHAVING COUNT(DISTINCT nf.engagement_id) \u003e= 1\nORDER BY c.id, occurrence_count DESC;",
                                         "options":  {

                                                     }
                                     },
                      "id":  "pg-get-patterns",
                      "name":  "Get Cross-Engagement Patterns",
                      "type":  "n8n-nodes-base.postgres",
                      "typeVersion":  2.5,
                      "position":  [
                                       460,
                                       300
                                   ],
                      "credentials":  {
                                          "postgres":  {
                                                           "id":  "oHS3dvjMW1h1PkMp",
                                                           "name":  "RECON OS PostgreSQL"
                                                       }
                                      }
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const patterns = $input.all().map(i =\u003e i.json);\nconst results = [];\n\nfor (const p of patterns) {\n  const occurrences = parseInt(p.occurrence_count||0);\n  const engagements = parseInt(p.engagement_count||0);\n  const timesReopened = parseInt(p.times_reopened||0);\n  const timesFixed = parseInt(p.times_fixed||0);\n\n  // Determine pattern type\n  let patternType = \u0027recurring\u0027;\n  let narrative = \u0027\u0027;\n\n  if (engagements \u003e= 3 \u0026\u0026 timesFixed \u003e 0 \u0026\u0026 timesReopened \u003e 0) {\n    patternType = \u0027systemic\u0027;\n    narrative = `${p.cwe_id} (${p.category}) has appeared in ${engagements} engagements for ${p.client_name}. Despite ${timesFixed} fix attempt(s), it has reopened ${timesReopened} time(s), indicating a systemic weakness in the development process.`;\n  } else if (engagements \u003e= 2) {\n    patternType = \u0027recurring\u0027;\n    narrative = `${p.cwe_id} (${p.category}) has recurred across ${engagements} engagements for ${p.client_name}. Pattern suggests this vulnerability class is not being addressed at root cause.`;\n  } else {\n    patternType = \u0027emerging\u0027;\n    narrative = `${p.cwe_id} (${p.category}) first detected for ${p.client_name}. Monitor for recurrence.`;\n  }\n\n  results.push({\n    client_id: p.client_id,\n    category: p.category,\n    cwe_id: p.cwe_id,\n    owasp_category: p.owasp_category,\n    occurrence_count: occurrences,\n    engagement_count: engagements,\n    first_seen: p.first_seen,\n    last_seen: p.last_seen,\n    pattern_type: patternType,\n    narrative\n  });\n}\n\n// Build summary for Slack\nconst systemic = results.filter(r =\u003e r.pattern_type === \u0027systemic\u0027);\nconst recurring = results.filter(r =\u003e r.pattern_type === \u0027recurring\u0027);\n\nconst slackSummary = [\n  `?? *RECON OS - Weekly Weakness Heatmap*`,\n  `Date: ${new Date().toISOString().split(\u0027T\u0027)[0]}`,\n  `Patterns analyzed: ${results.length}`,\n  systemic.length \u003e 0 ? `\\n?? *SYSTEMIC (${systemic.length})*:` : \u0027\u0027,\n  ...systemic.slice(0,3).map(s =\u003e `  . ${s.cwe_id} - ${s.client_id} - ${s.engagement_count} engagements, reopened ${s.occurrence_count}?`),\n  recurring.length \u003e 0 ? `\\n?? *RECURRING (${recurring.length})*:` : \u0027\u0027,\n  ...recurring.slice(0,3).map(r =\u003e `  . ${r.cwe_id} (${r.category}) - ${r.engagement_count} engagements`)\n].filter(Boolean).join(\u0027\\n\u0027);\n\nreturn [{ json: { patterns: results, slack_summary: slackSummary, systemic_count: systemic.length, total: results.length } }];"
                                     },
                      "id":  "analyze-patterns",
                      "name":  "Analyze Weakness Patterns",
                      "type":  "n8n-nodes-base.code",
