                      "id":  "test-anthropic-api",
                      "name":  "Test Anthropic API",
                      "type":  "n8n-nodes-base.httpRequest",
                      "typeVersion":  4.4,
                      "position":  [
                                       460,
                                       200
                                   ]
                  },
                  {
                      "parameters":  {
                                         "mode":  "runOnceForAllItems",
                                         "language":  "javaScript",
                                         "jsCode":  "const response = $(\u0027Test Anthropic API\u0027).first();\nconst status = response.statusCode;\nconst body = response.json;\n\nlet message = \u0027\u0027;\nlet apiWorking = false;\n\nif (status === 401 || status === 403) {\n  message = \u0027❌ ANTHROPIC_API_KEY invalid or has no credits (HTTP \u0027 + status + \u0027)\u0027;\n} else if (status === 200) {\n  message = \u0027✅ Anthropic API is working\u0027;\n  apiWorking = true;\n} else if (status === 429) {\n  message = \u0027⚠️ Anthropic API rate limited (HTTP 429)\u0027;\n} else if (status \u003e= 400 \u0026\u0026 status \u003c 500) {\n  message = \u0027❌ Anthropic API client error (HTTP \u0027 + status + \u0027)\u0027;\n} else if (status \u003e= 500) {\n  message = \u0027❌ Anthropic API server error (HTTP \u0027 + status + \u0027)\u0027;\n} else {\n  message = \u0027❓ Unexpected response (HTTP \u0027 + status + \u0027)\u0027;\n}\n\nreturn [{\n  json: {\n    message,\n    apiWorking,\n    statusCode: status,\n    responseBody: body\n  }\n}];"
                                     },
