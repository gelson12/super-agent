                      "parameters":  {
                                         "jsCode":  "const vaultRaw = $(\"Read 24H Signals\").first().json;\nconst outcomeRaw = $(\"Read Outcomes\").first().json;\nconst tickerRaw = $(\"Fetch Price\").first().json;\n\nconst memories = (vaultRaw \u0026\u0026 vaultRaw.memories) ? vaultRaw.memories : [];\nconst outcomes = (outcomeRaw \u0026\u0026 outcomeRaw.memories) ? outcomeRaw.memories : [];\nconst tickerResult = tickerRaw \u0026\u0026 tickerRaw.result ? tickerRaw.result : {};\nconst tickerKey = Object.keys(tickerResult)[0];\nconst ticker = tickerResult[tickerKey] || {};\nconst price = ticker.c ? parseFloat(ticker.c[0]) : 0;\nconst open = ticker.o ? parseFloat(ticker.o[1]) : price;\nconst change24h = open \u003e 0 ? Math.round(((price - open) / open) * 10000) / 100 : 0;\n\n// Count signals from last 24h vault entries\nlet buys = 0, sells = 0, waits = 0;\nconst last24h = new Date(Date.now() - 86400000).toISOString();\nfor (const m of memories) {\n  if (m.created_at \u003c last24h) continue;\n  const c = m.content || \"\";\n  if (c.match(/TRADE SIGNAL.*?BUY/)) buys++;\n  else if (c.match(/TRADE SIGNAL.*?SELL/)) sells++;\n  else if (c.match(/TRADE SIGNAL.*?WAIT/)) waits++;\n}\n\n// Latest outcome report\nlet hitRate = \"N/A\", outcomeSummary = \"No outcome data\";\nfor (const o of outcomes) {\n  const c = o.content || \"\";\n  const hrMatch = c.match(/Hit Rate:\\s*(\\d+)%/);\n  if (hrMatch) {\n    hitRate = hrMatch[1] + \"%\";\n    outcomeSummary = c.split(\"\\n\").slice(0, 4).join(\" | \");\n    break;\n  }\n}\n\nconst totalSignals = buys + sells + waits;\nconst now = new Date();\nconst dateStr = now.toISOString().slice(0, 10);\nconst hour = now.getUTCHours();\n\nconst report = `DAILY CRYPTO REPORT â ${dateStr}\nBTC/USD: $${Math.round(price)} (${change24h \u003e= 0 ? \"+\" : \"\"}${change24h}% 24H)\n\nSIGNALS (last 24h): ${totalSignals} total\nâ¢ BUY: ${buys} | SELL: ${sells} | WAIT: ${waits}\n\nPERFORMANCE:\nHit Rate: ${hitRate}\n${outcomeSummary}\n\nStatus: ${hitRate !== \"N/A\" \u0026\u0026 parseInt(hitRate) \u003e= 55 ? \"â\u0085 ABOVE threshold (55%)\" : hitRate !== \"N/A\" ? \"â ï¸ BELOW threshold â paper trading only\" : \"ð Accumulating data\"}`;\n\nreturn [{ json: { report, price, change24h, buys, sells, waits, hitRate, dateStr } }];"
