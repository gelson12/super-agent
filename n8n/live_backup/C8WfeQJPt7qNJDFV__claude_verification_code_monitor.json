                      "id":  "outlook-trigger",
                      "name":  "Watch Outlook for Anthropic Emails",
                      "type":  "n8n-nodes-base.microsoftOutlookTrigger",
                      "typeVersion":  1,
                      "position":  [
                                       240,
                                       400
                                   ],
                      "credentials":  {
                                          "microsoftOutlookOAuth2Api":  {
                                                                            "id":  "9paQ8IJLgiLbjEYI",
                                                                            "name":  "Microsoft Outlook account"
                                                                        }
                                      }
                  },
                  {
                      "parameters":  {
                                         "mode":  "runOnceForAllItems",
                                         "language":  "javaScript",
                                         "jsCode":  "const items = $input.all();\nconst results = [];\nfor (const item of items) {\n  const subject = (item.json.subject || \u0027\u0027).toLowerCase();\n  const body = item.json.bodyPreview || item.json.body?.content || \u0027\u0027;\n\n  // Only process Anthropic verification emails\n  if (!subject.includes(\u0027verification\u0027) \u0026\u0026 !subject.includes(\u0027code\u0027) \u0026\u0026 !subject.includes(\u0027anthropic\u0027) \u0026\u0026 !subject.includes(\u0027claude\u0027)) {\n    continue;\n  }\n\n  // Extract 6-digit code from email body\n  const codeMatch = body.match(/\\b(\\d{6})\\b/);\n  if (codeMatch) {\n    results.push({\n      json: {\n        code: codeMatch[1],\n        subject: item.json.subject,\n        from: item.json.from?.emailAddress?.address || \u0027\u0027,\n        timestamp: new Date().toISOString()\n      }\n    });\n  }\n}\n\nif (results.length === 0) {\n  return [];\n}\nreturn results;"
                                     },
                      "id":  "extract-code",
                      "name":  "Extract Verification Code",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       480,
                                       400
                                   ]
                  },
                  {
                      "parameters":  {
                                         "method":  "POST",
                                         "url":  "https://inspiring-cat-production.up.railway.app/webhook/verification-code",
                                         "authentication":  "none",
                                         "sendBody":  true,
                                         "contentType":  "json",
                                         "specifyBody":  "json",
                                         "jsonBody":  "={{ JSON.stringify({ code: $json.code }) }}",
                                         "options":  {
