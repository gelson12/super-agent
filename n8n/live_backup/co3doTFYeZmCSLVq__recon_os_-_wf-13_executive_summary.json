                  {
                      "parameters":  {
                                         "operation":  "executeQuery",
                                         "query":  "SELECT e.name as engagement_name, e.testing_window_start, e.testing_window_end, e.type,\n       c.name as client_name,\n       COUNT(nf.id) FILTER (WHERE nf.severity=\u0027critical\u0027) as criticals,\n       COUNT(nf.id) FILTER (WHERE nf.severity=\u0027high\u0027) as highs,\n       COUNT(nf.id) FILTER (WHERE nf.severity=\u0027medium\u0027) as mediums,\n       COUNT(nf.id) FILTER (WHERE nf.severity=\u0027low\u0027) as lows,\n       COUNT(nf.id) FILTER (WHERE nf.validation_status=\u0027verified_fixed\u0027) as fixed,\n       COUNT(nf.id) FILTER (WHERE nf.validation_status IN (\u0027validated\u0027,\u0027analyst_reviewed\u0027)) as open_validated,\n       COUNT(nf.id) FILTER (WHERE nf.is_recurring=true) as recurring,\n       ROUND(AVG(nf.recon_score),2) as avg_score,\n       em.total_assets, em.assets_tested, em.coverage_pct\nFROM engagements e\nJOIN clients c ON e.client_id = c.id\nLEFT JOIN normalized_findings nf ON nf.engagement_id = e.id\nLEFT JOIN engagement_metrics em ON em.engagement_id = e.id\nWHERE e.id = \u0027{{ $json.engagement_id }}\u0027\nGROUP BY e.id, e.name, e.testing_window_start, e.testing_window_end, e.type, c.name, em.total_assets, em.assets_tested, em.coverage_pct;",
                                         "options":  {

                                                     }
                                     },
                      "id":  "pg-get-stats",
                      "name":  "Get Engagement Stats",
                      "type":  "n8n-nodes-base.postgres",
                      "typeVersion":  2.5,
                      "position":  [
                                       680,
                                       300
                                   ],
                      "credentials":  {
                                          "postgres":  {
                                                           "id":  "oHS3dvjMW1h1PkMp",
                                                           "name":  "RECON OS PostgreSQL"
                                                       }
                                      }
                  },
                  {
                      "parameters":  {
                                         "operation":  "executeQuery",
                                         "query":  "SELECT nf.title, nf.severity, nf.recon_score, nf.score_explanation, nf.business_impact, a.asset_value\nFROM normalized_findings nf\nJOIN assets a ON nf.asset_id = a.id\nWHERE nf.engagement_id = \u0027{{ $(\u0027Normalize\u0027).first().json.engagement_id }}\u0027\n  AND nf.validation_status IN (\u0027validated\u0027,\u0027analyst_reviewed\u0027)\nORDER BY nf.recon_score DESC\nLIMIT 5;",
                                         "options":  {

                                                     }
                                     },
                      "id":  "pg-top-findings",
                      "name":  "Get Top 5 Findings",
                      "type":  "n8n-nodes-base.postgres",
                      "typeVersion":  2.5,
                      "position":  [
                                       900,
                                       300
                                   ],
                      "credentials":  {
                                          "postgres":  {
                                                           "id":  "oHS3dvjMW1h1PkMp",
                                                           "name":  "RECON OS PostgreSQL"
                                                       }
                                      }
                  },
                  {
                      "parameters":  {
                                         "operation":  "executeQuery",
                                         "query":  "SELECT owasp_category, COUNT(*) as count\nFROM normalized_findings\nWHERE engagement_id = \u0027{{ $(\u0027Normalize\u0027).first().json.engagement_id }}\u0027\n  AND owasp_category IS NOT NULL\nGROUP BY owasp_category\nORDER BY count DESC;",
                                         "options":  {

                                                     }
                                     },
                      "id":  "pg-owasp",
                      "name":  "Get OWASP Breakdown",
                      "type":  "n8n-nodes-base.postgres",
                      "typeVersion":  2.5,
                      "position":  [
                                       1120,
                                       300
                                   ],
                      "credentials":  {
                                          "postgres":  {
                                                           "id":  "oHS3dvjMW1h1PkMp",
                                                           "name":  "RECON OS PostgreSQL"
                                                       }
                                      }
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const stats = $(\u0027Get Engagement Stats\u0027).first().json;\nconst topFindings = $(\u0027Get Top 5 Findings\u0027).all().map(i =\u003e i.json);\nconst owaspBreakdown = $(\u0027Get OWASP Breakdown\u0027).all().map(i =\u003e i.json);\nconst engId = $(\u0027Normalize\u0027).first().json.engagement_id;\n\n// Determine overall risk posture\nlet riskPosture = \u0027Low\u0027;\nif (parseInt(stats.criticals) \u003e 0) riskPosture = \u0027Critical\u0027;\nelse if (parseInt(stats.highs) \u003e 2) riskPosture = \u0027High\u0027;\nelse if (parseInt(stats.highs) \u003e 0 || parseInt(stats.mediums) \u003e 3) riskPosture = \u0027Medium\u0027;\n\n// Build executive narrative\nconst totalFindings = parseInt(stats.criticals||0) + parseInt(stats.highs||0) + parseInt(stats.mediums||0) + parseInt(stats.lows||0);\nconst remediationPriority = topFindings.map((f,i) =\u003e `${i+1}. [${f.severity.toUpperCase()}] ${f.title} (${f.asset_value}) - Score: ${f.recon_score}/10`);\n\nconst executiveSummary = {\n  engagement: {\n    client: stats.client_name,\n    name: stats.engagement_name,\n    type: stats.type,\n    period: `${stats.testing_window_start?.split(\u0027T\u0027)[0]} to ${stats.testing_window_end?.split(\u0027T\u0027)[0]}`\n  },\n  risk_posture: riskPosture,\n  findings_summary: {\n    total: totalFindings,\n    critical: parseInt(stats.criticals||0),\n    high: parseInt(stats.highs||0),\n    medium: parseInt(stats.mediums||0),\n    low: parseInt(stats.lows||0),\n    fixed: parseInt(stats.fixed||0),\n    recurring: parseInt(stats.recurring||0),\n    average_risk_score: parseFloat(stats.avg_score||0)\n  },\n  asset_coverage: {\n    total_in_scope: parseInt(stats.total_assets||0),\n    tested: parseInt(stats.assets_tested||0),\n    coverage_pct: parseFloat(stats.coverage_pct||0)\n  },\n  top_priority_actions: remediationPriority,\n  owasp_categories_affected: owaspBreakdown.map(o =\u003e `${o.owasp_category}: ${o.count} finding(s)`),\n  key_observations: [\n    parseInt(stats.recurring||0) \u003e 0 ? `${stats.recurring} finding(s) are recurring from prior engagements - indicating systemic weaknesses.` : null,\n    riskPosture === \u0027Critical\u0027 ? \u0027At least one critical-severity finding requires immediate remediation.\u0027 : null,\n    parseFloat(stats.coverage_pct||0) \u003c 80 ? `Asset coverage is ${stats.coverage_pct}% - some in-scope assets were not fully tested.` : null\n  ].filter(Boolean),\n  generated_at: new Date().toISOString()\n};\n\nreturn [{ json: { engagement_id: engId, executive_summary: executiveSummary } }];"
                                     },
                      "id":  "build-exec-summary",
                      "name":  "Build Executive Summary",
                      "type":  "n8n-nodes-base.code",
