                                         "query":  "UPDATE engagement_metrics\nSET total_assets = (SELECT COUNT(*) FROM assets WHERE engagement_id = \u0027{{ $(\u0027Normalize Input\u0027).first().json.engagement_id }}\u0027),\n    updated_at = NOW()\nWHERE engagement_id = \u0027{{ $(\u0027Normalize Input\u0027).first().json.engagement_id }}\u0027;",
