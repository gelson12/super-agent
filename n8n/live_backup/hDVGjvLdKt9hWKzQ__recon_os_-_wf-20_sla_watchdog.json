                                                                           "field":  "cronExpression",
                                                                           "expression":  "30 8 * * *"
                                                                       }
                                                                   ]
                                                  }
                                     },
                      "id":  "cron-daily",
                      "name":  "Cron Daily 08:30",
                      "type":  "n8n-nodes-base.scheduleTrigger",
                      "typeVersion":  1.2,
                      "position":  [
                                       240,
                                       300
                                   ]
                  },
                  {
                      "parameters":  {
                                         "operation":  "executeQuery",
                                         "query":  "SELECT\n  nf.id as finding_id,\n  nf.title,\n  nf.severity,\n  nf.priority_bucket,\n  nf.validated_at,\n  nf.remediation_owner,\n  a.asset_value,\n  e.name as engagement_name,\n  c.name as client_name,\n  c.contact_email,\n  EXTRACT(DAYS FROM NOW() - nf.validated_at) as days_open,\n  CASE\n    WHEN nf.priority_bucket = \u0027immediate_attention\u0027 THEN 7\n    WHEN nf.priority_bucket = \u0027high_priority\u0027 THEN 30\n    WHEN nf.priority_bucket = \u0027medium_priority\u0027 THEN 90\n    WHEN nf.priority_bucket = \u0027low_priority\u0027 THEN 180\n    ELSE 999\n  END as sla_days,\n  CASE\n    WHEN nf.priority_bucket = \u0027immediate_attention\u0027 THEN EXTRACT(DAYS FROM NOW() - nf.validated_at) - 7\n    WHEN nf.priority_bucket = \u0027high_priority\u0027 THEN EXTRACT(DAYS FROM NOW() - nf.validated_at) - 30\n    WHEN nf.priority_bucket = \u0027medium_priority\u0027 THEN EXTRACT(DAYS FROM NOW() - nf.validated_at) - 90\n    ELSE -999\n  END as days_overdue\nFROM normalized_findings nf\nJOIN assets a ON nf.asset_id = a.id\nJOIN engagements e ON nf.engagement_id = e.id\nJOIN clients c ON e.client_id = c.id\nWHERE nf.validation_status = \u0027validated\u0027\n  AND nf.remediation_status NOT IN (\u0027verified_fixed\u0027,\u0027accepted_risk\u0027)\n  AND nf.validated_at IS NOT NULL\n  AND (\n    (nf.priority_bucket = \u0027immediate_attention\u0027 AND nf.validated_at \u003c NOW() - INTERVAL \u00275 days\u0027) OR\n    (nf.priority_bucket = \u0027high_priority\u0027 AND nf.validated_at \u003c NOW() - INTERVAL \u002724 days\u0027) OR\n    (nf.priority_bucket = \u0027medium_priority\u0027 AND nf.validated_at \u003c NOW() - INTERVAL \u002772 days\u0027)\n  )\nORDER BY days_overdue DESC;",
                                         "options":  {

                                                     }
                                     },
                      "id":  "pg-get-sla-items",
                      "name":  "Get SLA Items",
                      "type":  "n8n-nodes-base.postgres",
                      "typeVersion":  2.5,
                      "position":  [
                                       460,
                                       300
                                   ],
                      "credentials":  {
                                          "postgres":  {
                                                           "id":  "oHS3dvjMW1h1PkMp",
                                                           "name":  "RECON OS PostgreSQL"
                                                       }
                                      }
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const items = $input.all().map(i =\u003e i.json);\nif (items.length === 0) return [{ json: { has_items: false, digest: \u0027RECON OS SLA Watchdog: All clear - no SLA breaches.\u0027, overdue_critical: 0 } }];\n\nconst overdue = items.filter(i =\u003e parseFloat(i.days_overdue) \u003e 0);\nconst warning = items.filter(i =\u003e parseFloat(i.days_overdue) \u003c= 0);\nconst overdueCritical = overdue.filter(i =\u003e [\u0027immediate_attention\u0027,\u0027high_priority\u0027].includes(i.priority_bucket));\n\nconst formatItem = i =\u003e {\n  const daysOverdue = Math.round(parseFloat(i.days_overdue||0));\n  const tag = daysOverdue \u003e 0 ? `?? ${daysOverdue}d OVERDUE` : `?? ${Math.round(Math.abs(parseFloat(i.days_overdue||0)))}d to SLA`;\n  return `  ${tag} | [${i.severity?.toUpperCase()}] ${i.title}\\n    Client: ${i.client_name} | Asset: ${i.asset_value} | Owner: ${i.remediation_owner || \u0027Unassigned\u0027}`;\n};\n\nconst digest = [\n  `?? RECON OS - SLA Watchdog - ${new Date().toISOString().split(\u0027T\u0027)[0]}`,\n  `Total items at risk: ${items.length} (${overdue.length} overdue, ${warning.length} approaching)`,\n  ``,\n  overdue.length \u003e 0 ? `OVERDUE (${overdue.length}):` : \u0027\u0027,\n  ...overdue.map(formatItem),\n  ``,\n  warning.length \u003e 0 ? `APPROACHING SLA (${warning.length}):` : \u0027\u0027,\n  ...warning.slice(0,5).map(formatItem)\n].filter(l =\u003e l !== null \u0026\u0026 l !== \u0027\u0027).join(\u0027\\n\u0027);\n\nreturn [{ json: {\n  has_items: items.length \u003e 0,\n  digest,\n  overdue_count: overdue.length,\n  warning_count: warning.length,\n  overdue_critical: overdueCritical.length,\n  items\n} }];"
                                     },
