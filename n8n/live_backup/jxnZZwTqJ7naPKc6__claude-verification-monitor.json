                      "id":  "outlook-trigger",
                      "name":  "Watch Outlook for Anthropic Emails",
                      "type":  "n8n-nodes-base.microsoftOutlookTrigger",
                      "typeVersion":  1,
                      "position":  [
                                       240,
                                       400
                                   ],
                      "credentials":  {
                                          "microsoftOutlookOAuth2Api":  {
                                                                            "id":  "9paQ8IJLgiLbjEYI",
                                                                            "name":  "Microsoft Outlook account"
                                                                        }
                                      }
                  },
                  {
                      "parameters":  {
                                         "mode":  "runOnceForAllItems",
                                         "language":  "javaScript",
                                         "jsCode":  "const items = $input.all();\nconst results = [];\nfor (const item of items) {\n  const subject = (item.json.subject || \"\").toLowerCase();\n  const body = item.json.bodyPreview || item.json.body?.content || \"\";\n  if (!subject.includes(\"verification\") \u0026\u0026 !subject.includes(\"code\") \u0026\u0026 !subject.includes(\"anthropic\") \u0026\u0026 !subject.includes(\"claude\")) {\n    continue;\n  }\n  const codeMatch = body.match(/\\b(\\d{6})\\b/);\n  if (codeMatch) {\n    results.push({ json: { code: codeMatch[1], subject: item.json.subject, from: item.json.from?.emailAddress?.address || \"\", timestamp: new Date().toISOString() } });\n  }\n}\nif (results.length === 0) { return []; }\nreturn results;"
                                     },
                      "id":  "extract-code",
                      "name":  "Extract Verification Code",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       480,
                                       400
                                   ]
                  },
                  {
                      "parameters":  {
                                         "method":  "POST",
                                         "url":  "https://inspiring-cat-production.up.railway.app/webhook/verification-code",
                                         "authentication":  "none",
                                         "sendBody":  true,
                                         "contentType":  "json",
                                         "specifyBody":  "json",
                                         "jsonBody":  "={{ JSON.stringify({ code: $json.code }) }}",
                                         "options":  {
                                                         "timeout":  10000
                                                     }
                                     },
