                      "id":  "get-cli-health",
                      "name":  "Get CLI Worker Health",
                      "type":  "n8n-nodes-base.httpRequest",
                      "typeVersion":  4.4,
                      "position":  [
                                       460,
                                       600
                                   ]
                  },
                  {
                      "parameters":  {
                                         "mode":  "runOnceForAllItems",
                                         "language":  "javaScript",
                                         "jsCode":  "// Collect all inputs\nconst agentData = $(\u0027Get Agent Status\u0027).first().json;\nconst proData = $(\u0027Get CLI Pro Status\u0027).first().json;\nconst cliHealth = $(\u0027Get CLI Worker Health\u0027).first().json;\n\nconst workers = agentData.workers || [];\nconst issues = [];\nconst insights = [];\nconst now = Date.now() / 1000;\n\n// ── Check each agent ────────────────────────────────────────────────────\nfor (const w of workers) {\n  if (w.state === \u0027strike\u0027) {\n    issues.push(`${w.id} on STRIKE (${w.task || \u0027no credits\u0027})`);\n  } else if (w.state === \u0027sick\u0027) {\n    issues.push(`${w.id} is SICK — needs attention`);\n  } else if (w.state === \u0027idle\u0027 \u0026\u0026 w.last_worked_ago !== null \u0026\u0026 w.last_worked_ago \u003e 3600) {\n    insights.push(`${w.id} idle for ${Math.round(w.last_worked_ago/60)}min`);\n  } else if (w.last_worked === 0 \u0026\u0026 ![\u0027Gemini CLI\u0027,\u0027DeepSeek\u0027,\u0027Shell Agent\u0027,\u0027GitHub Agent\u0027].includes(w.id)) {\n    insights.push(`${w.id} has NEVER been active`);\n  }\n}\n\n// ── Check Claude CLI Pro ────────────────────────────────────────────────\nconst proAvailable = proData.pro_available;\nconst proMode = proData.mode || \u0027\u0027;\nconst cliDown = proData.cli_down || false;\n\nif (cliDown) {\n  issues.push(`Claude CLI Pro is DOWN (mode: ${proMode})`);\n} else if (proAvailable === false) {\n  issues.push(`Claude CLI Pro UNAVAILABLE — ${proMode}`);\n} else if (proAvailable === true) {\n  insights.push(`Claude CLI Pro: OK (mode: ${proMode})`);\n}\n\n// ── Check CLI worker ────────────────────────────────────────────────────\nconst cliWorkerOk = cliHealth.status === \u0027ok\u0027;\nconst claudeAvail = cliHealth.claude_available;\nconst geminiAvail = cliHealth.gemini_available;\n\nif (!cliWorkerOk) {\n  issues.push(`CLI Worker (inspiring-cat) DEGRADED — claude=${claudeAvail} gemini=${geminiAvail}`);\n} else {\n  if (!claudeAvail) issues.push(\u0027CLI Worker: Claude binary unavailable\u0027);\n  if (!geminiAvail) insights.push(\u0027Gemini CLI: not available on worker\u0027);\n}\n\n// ── Gemini on dashboard ─────────────────────────────────────────────────\nconst geminiWorker = workers.find(w =\u003e w.id === \u0027Gemini CLI\u0027);\nif (geminiWorker \u0026\u0026 geminiWorker.state === \u0027sleeping\u0027 \u0026\u0026 !proData.gemini_available) {\n  insights.push(\u0027Gemini CLI: not configured (no GEMINI_SESSION_TOKEN)\u0027);\n}\n\n// ── Strike count ────────────────────────────────────────────────────────\nconst onStrike = workers.filter(w =\u003e w.state === \u0027strike\u0027).length;\nconst apiAvailable = proData.api_available;\nif (onStrike \u003e= 2 \u0026\u0026 apiAvailable === false) {\n  issues.push(`ALL Anthropic API agents on strike — ANTHROPIC_API_KEY has no credits`);\n}\n\n// ── Build report ────────────────────────────────────────────────────────\nconst hasIssues = issues.length \u003e 0;\nconst status = hasIssues ? \u0027⚠️ ISSUES DETECTED\u0027 : \u0027✅ ALL SYSTEMS OK\u0027;\n\nconst lines = [\n  `${status} | ${new Date().toISOString()}`,\n  ...issues.map(i =\u003e `  ❌ ${i}`),\n  ...insights.map(i =\u003e `  ℹ️  ${i}`),\n  `  Workers: ${workers.filter(w=\u003ew.state===\u0027idle\u0027||w.state===\u0027working\u0027).length} active, ${onStrike} on strike, ${workers.filter(w=\u003ew.state===\u0027sick\u0027).length} sick`,\n];\n\nconst message = lines.join(\u0027 | \u0027);\n\nreturn [{ json: { message, hasIssues, issueCount: issues.length, issues, insights, status } }];"
                                     },
