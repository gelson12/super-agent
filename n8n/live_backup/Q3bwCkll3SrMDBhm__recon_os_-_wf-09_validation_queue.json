                                         "query":  "INSERT INTO validation_history (finding_id, previous_status, new_status, changed_by, notes)\nSELECT \u0027{{ $(\u0027Prepare Validation Update\u0027).first().json.finding_id }}\u0027,\n       validation_status,\n       \u0027{{ $(\u0027Prepare Validation Update\u0027).first().json.validation_status }}\u0027,\n       \u0027{{ $(\u0027Prepare Validation Update\u0027).first().json.analyst_id }}\u0027,\n       \u0027{{ $(\u0027Prepare Validation Update\u0027).first().json.analyst_notes.replace(/\u0027/g,\"\u0027\u0027\") }}\u0027\nFROM normalized_findings WHERE id = \u0027{{ $(\u0027Prepare Validation Update\u0027).first().json.finding_id }}\u0027;",
