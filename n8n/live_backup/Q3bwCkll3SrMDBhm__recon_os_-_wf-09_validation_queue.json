                      "typeVersion":  1.1,
                      "position":  [
                                       1120,
                                       500
                                   ]
                  },
                  {
                      "parameters":  {
                                         "operation":  "executeQuery",
                                         "query":  "SELECT nf.id, nf.title, nf.severity, nf.recon_score, nf.priority_bucket,\n       nf.validation_status, nf.first_seen, nf.is_recurring,\n       a.asset_value, e.name as engagement_name, c.name as client_name\nFROM normalized_findings nf\nJOIN assets a ON nf.asset_id = a.id\nJOIN engagements e ON nf.engagement_id = e.id\nJOIN clients c ON e.client_id = c.id\nWHERE nf.validation_status = \u0027pending_analyst\u0027\n  AND e.status = \u0027active\u0027\nORDER BY nf.recon_score DESC\nLIMIT 50;",
                                         "options":  {

                                                     }
                                     },
                      "id":  "pg-pending-findings",
                      "name":  "Get Pending Findings",
                      "type":  "n8n-nodes-base.postgres",
                      "typeVersion":  2.5,
                      "position":  [
                                       460,
                                       300
                                   ],
                      "credentials":  {
                                          "postgres":  {
                                                           "id":  "oHS3dvjMW1h1PkMp",
                                                           "name":  "RECON OS PostgreSQL"
                                                       }
                                      }
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const findings = $input.all().map(i =\u003e i.json);\nconst immediate = findings.filter(f =\u003e f.priority_bucket === \u0027immediate_attention\u0027);\nconst high = findings.filter(f =\u003e f.priority_bucket === \u0027high_priority\u0027);\nconst medium = findings.filter(f =\u003e f.priority_bucket === \u0027medium_priority\u0027);\nconst other = findings.filter(f =\u003e ![\u0027immediate_attention\u0027,\u0027high_priority\u0027,\u0027medium_priority\u0027].includes(f.priority_bucket));\n\nconst N8N_URL = \u0027https://outstanding-blessing-production-1d4b.up.railway.app\u0027;\n\nconst formatFinding = f =\u003e\n  `. [${f.severity?.toUpperCase()}] ${f.title}\\n  Asset: ${f.asset_value} | Client: ${f.client_name}\\n  Score: ${f.recon_score} | Validate: POST ${N8N_URL}/webhook/recon-os/findings/validate\\n  Body: {\"finding_id\":\"${f.id}\",\"validation_status\":\"validated\",\"analyst_notes\":\"...\"}`;\n\nconst digest = [\n  `RECON OS - Daily Analyst Queue`,\n  `Date: ${new Date().toISOString().split(\u0027T\u0027)[0]}`,\n  `Total pending: ${findings.length} findings`,\n  \u0027\u0027,\n  immediate.length \u003e 0 ? `?? IMMEDIATE ATTENTION (${immediate.length}):\\n${immediate.slice(0,5).map(formatFinding).join(\u0027\\n\u0027)}` : \u0027\u0027,\n  high.length \u003e 0 ? `?? HIGH PRIORITY (${high.length}):\\n${high.slice(0,5).map(formatFinding).join(\u0027\\n\u0027)}` : \u0027\u0027,\n  medium.length \u003e 0 ? `?? MEDIUM PRIORITY (${medium.length})` : \u0027\u0027,\n  other.length \u003e 0 ? `? OTHER (${other.length})` : \u0027\u0027,\n  \u0027\u0027,\n  `Validation options: validated | analyst_reviewed | likely_false_positive`\n].filter(Boolean).join(\u0027\\n\u0027);\n\nreturn [{ json: { digest, finding_count: findings.length, immediate_count: immediate.length } }];"
                                     },
