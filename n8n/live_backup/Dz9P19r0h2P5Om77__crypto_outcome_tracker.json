                  {
                      "typeVersion":  2,
                      "parameters":  {
                                         "jsCode":  "const tickerRaw = $(\u0027Fetch BTC Price\u0027).first().json;\nconst tickerResult = tickerRaw \u0026\u0026 tickerRaw.result ? tickerRaw.result : {};\nconst tickerKey = Object.keys(tickerResult)[0];\nconst ticker = tickerResult[tickerKey] || {};\nconst currentPrice = ticker.c ? parseFloat(ticker.c[0]) : 0;\n\nconst vaultRaw = $(\u0027Read Vault Signals\u0027).first().json;\nconst memories = (vaultRaw \u0026\u0026 vaultRaw.memories) ? vaultRaw.memories : [];\n\nlet correct = 0, incorrect = 0, neutral = 0, evaluated = 0;\nconst outcomes = [];\n\nfor (const mem of memories) {\n  const content = mem.content || \u0027\u0027;\n  const dirMatch = content.match(/TRADE SIGNAL[^:]*:\\s*(BUY|SELL|WAIT)/);\n  const priceMatch = content.match(/@\\s*\\$(\\d+(?:\\.\\d+)?)/);\n  const confMatch = content.match(/Conf:\\s*([\\d.]+)%/);\n  if (!dirMatch || !priceMatch) continue;\n  const dir = dirMatch[1];\n  const signalPrice = parseFloat(priceMatch[1]);\n  const conf = confMatch ? parseFloat(confMatch[1]) : 0;\n  if (dir === \u0027WAIT\u0027) { neutral++; evaluated++; continue; }\n  if (currentPrice === 0 || signalPrice === 0) continue;\n  const pctMove = ((currentPrice - signalPrice) / signalPrice) * 100;\n  let outcome;\n  if (Math.abs(pctMove) \u003c 0.3) { outcome = \u0027TOO_SOON\u0027; }\n  else if (dir === \u0027BUY\u0027 \u0026\u0026 pctMove \u003e 0) { outcome = \u0027CORRECT\u0027; correct++; }\n  else if (dir === \u0027SELL\u0027 \u0026\u0026 pctMove \u003c 0) { outcome = \u0027CORRECT\u0027; correct++; }\n  else { outcome = \u0027INCORRECT\u0027; incorrect++; }\n  evaluated++;\n  outcomes.push({ dir, signalPrice, currentPrice: Math.round(currentPrice), pctMove: Math.round(pctMove * 100) / 100, conf, outcome });\n}\n\nconst total = correct + incorrect;\nconst hitRate = total \u003e 0 ? Math.round((correct / total) * 100) : 0;\nconst avgConf = outcomes.length \u003e 0 ? Math.round(outcomes.reduce((s, o) =\u003e s + o.conf, 0) / outcomes.length * 10) / 10 : 0;\nconst summary = `OUTCOME REPORT | ${new Date().toISOString().slice(0,16)}Z\\nBTC @ $${Math.round(currentPrice)}\\nSignals evaluated: ${evaluated} | Correct: ${correct} | Incorrect: ${incorrect} | Neutral: ${neutral}\\nHit Rate: ${hitRate}% | Avg Confidence: ${avgConf}%\\nLast 3: ${outcomes.slice(0,3).map(o =\u003e o.dir + \u0027 \u0027 + o.outcome + \u0027 (\u0027 + o.pctMove + \u0027%)\u0027).join(\u0027 | \u0027)}`;\nreturn [{ json: { summary, hitRate, correct, incorrect, neutral, evaluated, currentPrice, avgConf, outcomes: outcomes.slice(0, 10) } }];"
                                     },
