                  {
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "name":  "Check Spike",
                      "parameters":  {
                                         "jsCode":  "const raw = $(\"Fetch 1M Ticker\").first().json;\nconst result = raw \u0026\u0026 raw.result ? raw.result : {};\nconst key = Object.keys(result)[0];\nconst ticker = result[key] || {};\nconst price = ticker.c ? parseFloat(ticker.c[0]) : 0;\nconst high24 = ticker.h ? parseFloat(ticker.h[0]) : price;\nconst low24 = ticker.l ? parseFloat(ticker.l[0]) : price;\nconst open24 = ticker.o ? parseFloat(ticker.o[1]) : price;\n\n// ATR proxy: (high - low) / open as % â crude but instant\nconst atrPct = open24 \u003e 0 ? ((high24 - low24) / open24) * 100 : 0;\n\n// Price move from open in past 24h\nconst priceMove = open24 \u003e 0 ? Math.abs((price - open24) / open24) * 100 : 0;\n\n// Spike thresholds\nconst ATR_SPIKE = 4.0;   // 4% high-low range = elevated vol\nconst PRICE_SPIKE = 3.0; // 3% move from open = significant\n\nconst triggered = atrPct \u003e ATR_SPIKE || priceMove \u003e PRICE_SPIKE;\nconst reason = [];\nif (atrPct \u003e ATR_SPIKE) reason.push(`ATR ${atrPct.toFixed(2)}% \u003e ${ATR_SPIKE}%`);\nif (priceMove \u003e PRICE_SPIKE) reason.push(`Move ${priceMove.toFixed(2)}% \u003e ${PRICE_SPIKE}%`);\n\nreturn [{ json: { triggered, price, atrPct: Math.round(atrPct * 100) / 100, priceMove: Math.round(priceMove * 100) / 100, reason: reason.join(\" | \"), ts: new Date().toISOString() } }];"
                                     },
