                      "name":  "Check Spike",
                      "typeVersion":  2,
                      "type":  "n8n-nodes-base.code",
                      "parameters":  {
                                         "jsCode":  "// ââ Volatility Watchdog + Telegram message ââââââââââââââââââââââââââââââââââââ\nconst raw    = $(\"Fetch 1M Ticker\").first().json;\nconst result = raw \u0026\u0026 raw.result ? raw.result : {};\nconst key    = Object.keys(result)[0];\nconst ticker = result[key] || {};\nconst price  = ticker.c ? parseFloat(ticker.c[0]) : 0;\nif (!price) {\n  return [{ json: { triggered: false, reason: \u0027No price data\u0027, price: 0, ts: new Date().toISOString(), telegramMsg: \u0027\u0027 } }];\n}\n\n// Kraken ticker: index [0]=today, [1]=24h rolling\nconst high24    = ticker.h ? parseFloat(ticker.h[1]) : price;\nconst low24     = ticker.l ? parseFloat(ticker.l[1]) : price;\nconst open24    = ticker.o ? parseFloat(ticker.o[1]) : price;\nconst vwap24    = ticker.p ? parseFloat(ticker.p[1]) : price;\nconst highToday = ticker.h ? parseFloat(ticker.h[0]) : price;\nconst lowToday  = ticker.l ? parseFloat(ticker.l[0]) : price;\n\nconst range24pct = open24 \u003e 0 ? ((high24 - low24) / open24) * 100 : 0;\nconst rangeToday = open24 \u003e 0 ? ((highToday - lowToday) / open24) * 100 : 0;\nconst vwapDev    = vwap24 \u003e 0 ? ((price - vwap24) / vwap24) * 100 : 0;\nconst vwapDevAbs = Math.abs(vwapDev);\nconst priceMove  = open24 \u003e 0 ? Math.abs((price - open24) / open24) * 100 : 0;\nconst rangePos   = (high24 \u003e low24) ? (price - low24) / (high24 - low24) : 0.5;\nconst atExtreme  = rangePos \u003e 0.95 || rangePos \u003c 0.05;\n\nconst RANGE_SPIKE_PCT = 6.0;\nconst PRICE_MOVE_PCT  = 3.0;\nconst VWAP_DEV_PCT    = 2.0;\n\nconst rangeSpike   = range24pct \u003e RANGE_SPIKE_PCT;\nconst priceSpike   = priceMove  \u003e PRICE_MOVE_PCT;\nconst vwapSpike    = vwapDevAbs \u003e VWAP_DEV_PCT;\nconst breakoutSpike = atExtreme \u0026\u0026 rangeToday \u003e 2.0;\n\nconst triggered = rangeSpike || priceSpike || vwapSpike || breakoutSpike;\n\nconst reason = [];\nif (rangeSpike)    reason.push(\u002724H range \u0027 + range24pct.toFixed(2) + \u0027% \u003e \u0027 + RANGE_SPIKE_PCT + \u0027%\u0027);\nif (priceSpike)    reason.push(\u0027Price move \u0027 + priceMove.toFixed(2) + \u0027% from open\u0027);\nif (vwapSpike)     reason.push(\u0027VWAP dev \u0027 + vwapDevAbs.toFixed(2) + \u0027% (\u0027 + (vwapDev \u003e 0 ? \u0027above\u0027 : \u0027below\u0027) + \u0027)\u0027);\nif (breakoutSpike) reason.push(\u0027Range extreme (\u0027 + (rangePos * 100).toFixed(0) + \u0027%) + intraday \u0027 + rangeToday.toFixed(2) + \u0027%\u0027);\n\nconst ts = new Date().toISOString();\n\n// ââ Build Telegram Message (only sent when triggered=true) ââââââââââââââââââââ\nconst HR = \u0027\\u2501\u0027.repeat(20);\nconst spikeType  = rangeSpike || priceSpike ? \u0027HIGH\u0027 : \u0027MODERATE\u0027;\nconst spikeEmoji = spikeType === \u0027HIGH\u0027 ? \u0027\\uD83D\\uDEA8\\uD83D\\uDEA8\u0027 : \u0027\\u26A1\\u26A1\u0027;\nconst priceDir   = price \u003e open24 ? \u0027\\uD83D\\uDE80 ABOVE open\u0027 : \u0027\\uD83D\\uDD3B BELOW open\u0027;\nconst vwapDir    = vwapDev \u003e 0 ? \u0027\\uD83D\\uDFE2 above VWAP\u0027 : \u0027\\uD83D\\uDD34 below VWAP\u0027;\nconst extremeLabel = rangePos \u003e 0.95 ? \u0027\\uD83D\\uDFE2 near day HIGH \\u2014 breakout zone\u0027 : rangePos \u003c 0.05 ? \u0027\\uD83D\\uDD34 near day LOW \\u2014 breakdown zone\u0027 : \u0027\\uD83D\\uDFE1 mid-range\u0027;\n\nconst telegramMsg = [\n  spikeEmoji + \u0027 \u003cb\u003eVOLATILITY SPIKE DETECTED\u003c/b\u003e \u0027 + spikeEmoji,\n  \u0027\\uD83D\\uDDD3 \u0027 + ts.replace(\u0027T\u0027, \u0027 \u0027).slice(0, 19) + \u0027 UTC\u0027,\n  \u0027\u0027,\n  HR,\n  \u0027\\uD83D\\uDCB0 BTC/USD: \u003cb\u003e$\u0027 + Math.round(price).toLocaleString(\u0027en-US\u0027) + \u0027\u003c/b\u003e  \\u00B7  \u0027 + priceDir,\n  \u0027\\uD83D\\uDCC8 24H Range: \u003cb\u003e\u0027 + range24pct.toFixed(2) + \u0027%\u003c/b\u003e\u0027 + (rangeSpike ? \u0027 \\u26A0\\uFE0F SPIKE\u0027 : \u0027\u0027),\n  \u0027\\uD83D\\uDCD0 Intraday Range: \u003cb\u003e\u0027 + rangeToday.toFixed(2) + \u0027%\u003c/b\u003e\u0027,\n  \u0027\\uD83C\\uDFAF VWAP Dev: \u003cb\u003e\u0027 + (vwapDev \u003e= 0 ? \u0027+\u0027 : \u0027\u0027) + vwapDev.toFixed(2) + \u0027%\u003c/b\u003e  \\u00B7  \u0027 + vwapDir,\n  \u0027\\uD83D\\uDCCD Range Position: \u003cb\u003e\u0027 + (rangePos * 100).toFixed(0) + \u0027%\u003c/b\u003e  \\u00B7  \u0027 + extremeLabel,\n  \u0027\u0027,\n  HR,\n  \u0027\\uD83D\\uDD0D \u003cb\u003eTrigger reasons:\u003c/b\u003e\u0027,\n  reason.map(r =\u003e \u0027\\u2022 \u0027 + r).join(\u0027\\n\u0027) || \u0027\\u2022 Composite spike score\u0027,\n  \u0027\u0027,\n  \u0027\\uD83D\\uDD04 \u003cb\u003eAction:\u003c/b\u003e Extra analysis scan triggered outside 5-min schedule\u0027,\n  \u0027\u0027,\n  \u0027\u003ci\u003e\\u23F1 Normal schedule resumes in 5 min  \\u00B7  v3-super\u003c/i\u003e\u0027\n].join(\u0027\\n\u0027);\n\nreturn [{ json: {\n  triggered,\n  price,\n  range24pct:  Math.round(range24pct  * 100) / 100,\n  rangeToday:  Math.round(rangeToday  * 100) / 100,\n  priceMove:   Math.round(priceMove   * 100) / 100,\n  vwapDev:     Math.round(vwapDev     * 100) / 100,\n  rangePos:    Math.round(rangePos    * 100) / 100,\n  atExtreme,\n  reason: reason.join(\u0027 | \u0027) || \u0027normal vol\u0027,\n  ts,\n  telegramMsg: triggered ? telegramMsg : \u0027\u0027\n}}];\n"
                                     }
