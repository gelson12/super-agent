    "nodes":  [
                  {
                      "id":  "tg01",
                      "name":  "Telegram Trigger",
                      "type":  "n8n-nodes-base.telegramTrigger",
                      "typeVersion":  1.2,
                      "position":  [
                                       0,
                                       300
                                   ],
                      "credentials":  {
                                          "telegramApi":  {
                                                              "id":  "vaWr2cxS1Q9HsYd4",
                                                              "name":  "Telegram account"
                                                          }
                                      },
                      "parameters":  {
                                         "updates":  [
                                                         "message"
                                                     ],
                                         "additionalFields":  {

                                                              }
                                     },
                      "webhookId":  "d99e7618-3352-4a96-a7e2-5dec78ba2b2a"
                  },
                  {
                      "id":  "tg02",
                      "name":  "Extract Message",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       200,
                                       300
                                   ],
                      "parameters":  {
                                         "jsCode":  "const msg = $json.message || $json;\nconst text = msg.text || msg.caption || \u0027(no text)\u0027;\nconst chatId = String(msg.chat \u0026\u0026 msg.chat.id ? msg.chat.id : \u00276275020593\u0027);\nconst username = msg.from \u0026\u0026 msg.from.username ? msg.from.username : (msg.from \u0026\u0026 msg.from.first_name ? msg.from.first_name : \u0027User\u0027);\nconst msgId = msg.message_id;\nconst prompt = \u0027You are Claude, an AI assistant powered by Claude CLI Pro. Reply to \u0027 + username + \u0027: \u0027 + text + \u0027\\n\\nBe helpful and concise. Max 400 words unless it is a technical question.\u0027;\nreturn [{ json: { chatId, username, msgId, type: \u0027claude_pro\u0027, payload: { prompt } } }];"
                                     }
                  },
                  {
                      "id":  "tg03",
                      "name":  "Submit to Claude CLI",
                      "type":  "n8n-nodes-base.httpRequest",
                      "typeVersion":  4.2,
                      "position":  [
                                       400,
                                       300
                                   ],
                      "onError":  "continueRegularOutput",
                      "parameters":  {
                                         "method":  "POST",
                                         "url":  "https://inspiring-cat-production.up.railway.app/tasks",
                                         "sendHeaders":  true,
                                         "headerParameters":  {
                                                                  "parameters":  [
                                                                                     {
                                                                                         "name":  "Content-Type",
                                                                                         "value":  "application/json"
                                                                                     }
                                                                                 ]
                                                              },
                                         "sendBody":  true,
                                         "contentType":  "raw",
                                         "rawContentType":  "application/json",
                                         "body":  "={{ JSON.stringify({type: $json.type, payload: $json.payload}) }}",
                                         "options":  {
                                                         "response":  {
                                                                          "response":  {
                                                                                           "neverError":  true
                                                                                       }
                                                                      },
                                                         "timeout":  15000
                                                     }
                                     }
                  },
                  {
                      "id":  "tg04",
                      "name":  "Poll Claude Result",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       600,
                                       300
                                   ],
                      "parameters":  {
                                         "jsCode":  "const https = require(\u0027https\u0027);\nconst sub = $(\u0027Submit to Claude CLI\u0027).first().json;\nconst taskId = sub.task_id;\nconst chatId = $(\u0027Extract Message\u0027).first().json.chatId;\nconst userText = $(\u0027Extract Message\u0027).first().json.text;\n\nif (!taskId) {\n  return [{json:{chatId, reply:\u0027Sorry, I had trouble connecting to Claude right now. Please try again!\u0027}}];\n}\n\nfor (let i=0;i\u003c40;i++) {\n  await new Promise(r=\u003esetTimeout(r,3000));\n  const poll = await new Promise((resolve,reject)=\u003e{\n    https.get(\u0027https://inspiring-cat-production.up.railway.app/tasks/\u0027+taskId,res=\u003e{\n      let body=\u0027\u0027;\n      res.on(\u0027data\u0027,c=\u003ebody+=c);\n      res.on(\u0027end\u0027,()=\u003e{try{resolve(JSON.parse(body));}catch(e){resolve({status:\u0027error\u0027,result:body});}});\n    }).on(\u0027error\u0027,reject);\n  });\n  if (poll.status===\u0027done\u0027) {\n    const reply = (poll.result||\u0027No response\u0027).slice(0,4000);\n    return [{json:{chatId, reply}}];\n  }\n  if (poll.status===\u0027failed\u0027) {\n    return [{json:{chatId, reply:\u0027Claude encountered an error: \u0027+(poll.error||\u0027unknown\u0027)}}];\n  }\n}\nreturn [{json:{chatId, reply:\u0027Claude took too long to respond. Please try again!\u0027}}];"
                                     }
                  },
