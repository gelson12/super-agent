                                                               "jsCode":  "// 芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬\n// CRYPTO SPECIALIST v3 芒聙聰 Rich Dashboard Builder\n// Reads from upstream n8n nodes (sequential chain)\n// 芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬\n\nconst tickerRaw = $(\u0027Fetch BTC\u0027).first().json;\nconst signalsRaw = $(\u0027Read Signals\u0027).first().json;\nconst outcomesRaw = $(\u0027Read Outcomes\u0027).first().json;\n\n// 芒聰聙芒聰聙 BTC Price Data 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙\nconst r = (tickerRaw \u0026\u0026 tickerRaw.result) ? tickerRaw.result : {};\nconst k = Object.keys(r)[0];\nconst t = r[k] || {};\nconst price   = t.c ? parseFloat(t.c[0]) : 0;\nconst openDay = t.o ? parseFloat(t.o) : price;          // FIX: o is string, not array\nconst high24  = t.h ? parseFloat(t.h[1]) : price;\nconst low24   = t.l ? parseFloat(t.l[1]) : price;\nconst vwap24  = t.p ? parseFloat(t.p[1]) : price;\nconst vol24btc = t.v ? parseFloat(t.v[1]) : 0;\nconst vol24usd = Math.round(vol24btc * vwap24 / 1e6);\nconst trades24 = t.t ? t.t[1] : 0;\nconst bid      = t.b ? parseFloat(t.b[0]) : price;\nconst ask      = t.a ? parseFloat(t.a[0]) : price;\nconst spread   = (ask - bid).toFixed(2);\nconst change24h = openDay \u003e 0 ? ((price - openDay) / openDay) * 100 : 0;\nconst c24Str   = (change24h \u003e= 0 ? \u0027+\u0027 : \u0027\u0027) + change24h.toFixed(2) + \u0027%\u0027;\nconst rangePos = high24 \u003e low24 ? Math.round(((price - low24) / (high24 - low24)) * 100) : 50;\n\n// 芒聰聙芒聰聙 Signal History 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙\nconst memories = (signalsRaw \u0026\u0026 signalsRaw.memories) ? signalsRaw.memories : [];\nconst signals = [];\nfor (const m of memories.slice(0, 10)) {\n  const c = m.content || \u0027\u0027;\n  const dir  = (c.match(/TRADE SIGNAL[^:]*:\\s*(BUY|SELL|WAIT)/) || [])[1];\n  const px   = (c.match(/@\\s*\\$(\\d+)/) || [])[1];\n  const conf = (c.match(/Conf[idence]*[:\\s]+([\\d.]+)%/) || [])[1];\n  const rsi  = (c.match(/RSI[:\\s]+([\\d.]+)/) || [])[1];\n  const reg  = (c.match(/Regime[:\\s]+(\\S+?)(?:\\s|$|\\|)/) || [])[1];\n  const quor = (c.match(/Quorum[:\\s]+(\\d+)/) || [])[1];\n  const nts  = (c.match(/No.?Trade[:\\s]+([\\d.]+)/) || [])[1];\n  const ts   = m.created_at ? m.created_at.slice(11,16) : \u0027?\u0027;\n  if (!dir) continue;\n  signals.push({ dir, px: px||\u0027?\u0027, conf: conf||\u0027?\u0027, rsi: rsi||\u0027?\u0027, reg: reg||\u0027?\u0027, quor: quor||\u0027?\u0027, nts: nts||\u0027?\u0027, ts });\n}\nconst last = signals[0] || {};\nconst confNum = parseFloat(last.conf) || 0;\n\n// Signal counts\nconst buyCnt  = signals.filter(s =\u003e s.dir === \u0027BUY\u0027).length;\nconst sellCnt = signals.filter(s =\u003e s.dir === \u0027SELL\u0027).length;\nconst waitCnt = signals.filter(s =\u003e s.dir === \u0027WAIT\u0027).length;\n\n// 芒聰聙芒聰聙 Outcome Data 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙\nconst outMems = (outcomesRaw \u0026\u0026 outcomesRaw.memories) ? outcomesRaw.memories : [];\nlet hitRate = -1, hitCorrect = 0, hitIncorrect = 0, hitTotal = 0, hitAvgConf = 0;\nfor (const o of outMems) {\n  const c = o.content || \u0027\u0027;\n  const hr = (c.match(/Hit Rate[:\\s]+([\\d.]+)%/) || [])[1];\n  if (hr) {\n    hitRate = parseInt(hr);\n    hitCorrect = parseInt((c.match(/Correct[:\\s]+(\\d+)/) || [])[1] || 0);\n    hitIncorrect = parseInt((c.match(/Incorrect[:\\s]+(\\d+)/) || [])[1] || 0);\n    hitTotal = hitCorrect + hitIncorrect;\n    hitAvgConf = parseFloat((c.match(/Avg Confidence[:\\s]+([\\d.]+)%/) || [])[1] || 0);\n    break;\n  }\n}\n\n// 芒聰聙芒聰聙 Helper Functions 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙\nconst fmt  = n =\u003e Math.round(n).toLocaleString(\u0027en-US\u0027);\nconst fmtK = n =\u003e n \u003e= 1000 ? (n/1000).toFixed(1) + \u0027K\u0027 : n.toString();\nconst pCol = change24h \u003e= 0 ? \u0027#00d97e\u0027 : \u0027#ff4d6d\u0027;\nconst dCol = d =\u003e d === \u0027BUY\u0027 ? \u0027#00d97e\u0027 : d === \u0027SELL\u0027 ? \u0027#ff4d6d\u0027 : \u0027#8892a4\u0027;\nconst dBg  = d =\u003e d === \u0027BUY\u0027 ? \u0027rgba(0,217,126,0.12)\u0027 : d === \u0027SELL\u0027 ? \u0027rgba(255,77,109,0.12)\u0027 : \u0027rgba(136,146,164,0.08)\u0027;\nconst dIcon = d =\u003e d === \u0027BUY\u0027 ? \u0027芒聳虏\u0027 : d === \u0027SELL\u0027 ? \u0027芒聳录\u0027 : \u0027芒聴聠\u0027;\nconst hCol = hitRate \u003e= 55 ? \u0027#00d97e\u0027 : hitRate \u003e= 0 ? \u0027#ff4d6d\u0027 : \u0027#8892a4\u0027;\nconst regLabel = (r) =\u003e {\n  const m = {\u0027BULL_TREND_STRONG\u0027:\u0027冒聼聼垄 Bull Strong\u0027,\u0027BULL_TREND_WEAK\u0027:\u0027冒聼聼隆 Bull Weak\u0027,\u0027BEAR_TREND_STRONG\u0027:\u0027冒聼聰麓 Bear Strong\u0027,\u0027BEAR_TREND_WEAK\u0027:\u0027冒聼聼聽 Bear Weak\u0027,\u0027RANGING\u0027:\u0027芒卢聹 Ranging\u0027,\u0027CHOPPY\u0027:\u0027冒聼聰碌 Choppy\u0027,\u0027EXTREME_CAUTION\u0027:\u0027冒聼職篓 Caution\u0027,\u0027BREAKOUT\u0027:\u0027芒職隆 Breakout\u0027};\n  return m[r] || r || \u0027芒聙聰\u0027;\n};\n\n// 芒聰聙芒聰聙 Signal Rows 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙\nconst sigRows = signals.map(s =\u003e `\n\u003ctr class=\"sig-row\" data-dir=\"${s.dir}\"\u003e\n  \u003ctd class=\"ts-cell\"\u003e${s.ts}\u003c/td\u003e\n  \u003ctd\u003e\u003cspan class=\"dir-badge\" style=\"color:${dCol(s.dir)};background:${dBg(s.dir)}\"\u003e${dIcon(s.dir)} ${s.dir}\u003c/span\u003e\u003c/td\u003e\n  \u003ctd class=\"mono\"\u003e$${parseInt(s.px||0).toLocaleString()}\u003c/td\u003e\n  \u003ctd\u003e\n    \u003cdiv class=\"conf-pill\"\u003e\n      \u003cdiv class=\"conf-fill\" style=\"width:${s.conf}%;background:${dCol(s.dir)}\"\u003e\u003c/div\u003e\n      \u003cspan class=\"conf-num\"\u003e${s.conf}%\u003c/span\u003e\n    \u003c/div\u003e\n  \u003c/td\u003e\n  \u003ctd class=\"rsi-cell\"\u003e\u003cspan class=\"tooltip-wrap\"\u003e${s.rsi}\u003cspan class=\"tt\"\u003eRSI: Relative Strength Index. \u003c50 = bearish momentum, \u003e50 = bullish.\u003c/span\u003e\u003c/span\u003e\u003c/td\u003e\n  \u003ctd\u003e${regLabel(s.reg)}\u003c/td\u003e\n\u003c/tr\u003e`).join(\u0027\u0027) || `\u003ctr\u003e\u003ctd colspan=\"6\" class=\"empty-row\"\u003eNo signals yet 芒聙聰 workflow runs every 5 min\u003c/td\u003e\u003c/tr\u003e`;\n\n// 芒聰聙芒聰聙 HTML 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙\nconst html = `\u003c!DOCTYPE html\u003e\n\u003chtml lang=\"en\"\u003e\n\u003chead\u003e\n\u003cmeta charset=\"UTF-8\"\u003e\u003cmeta name=\"viewport\" content=\"width=device-width,initial-scale=1\"\u003e\n\u003cmeta http-equiv=\"refresh\" content=\"300\"\u003e\n\u003ctitle\u003eCrypto Specialist v3 芒聙聰 Live\u003c/title\u003e\n\u003cstyle\u003e\n:root{\n  --bg:#070b14;--bg2:#0d1421;--card:#111827;--card2:#151e2d;\n  --border:#1e293b;--border2:#243044;\n  --txt:#e2e8f0;--muted:#64748b;--muted2:#8892a4;\n  --blue:#3b82f6;--cyan:#06b6d4;--green:#00d97e;--red:#ff4d6d;\n  --yellow:#f59e0b;--purple:#a855f7;\n  --glow-green:rgba(0,217,126,0.15);\n  --glow-blue:rgba(59,130,246,0.15);\n}\n*{box-sizing:border-box;margin:0;padding:0}\nhtml{overflow-y:scroll}\nbody{background:var(--bg);color:var(--txt);font-family:-apple-system,BlinkMacSystemFont,\"Segoe UI\",\"Inter\",sans-serif;min-height:100vh;padding:0}\n\n/* Animated gradient BG */\nbody::before{\n  content:\"\";position:fixed;inset:0;z-index:-1;\n  background:radial-gradient(ellipse 80% 60% at 20% -10%,rgba(59,130,246,0.07) 0%,transparent 60%),\n             radial-gradient(ellipse 60% 50% at 80% 110%,rgba(0,217,126,0.05) 0%,transparent 60%),\n             radial-gradient(ellipse 40% 40% at 50% 50%,rgba(168,85,247,0.03) 0%,transparent 70%),\n             var(--bg);\n}\n\n/* 芒聰聙芒聰聙 HEADER 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙 */\n.hdr{\n  display:flex;align-items:center;justify-content:space-between;\n  padding:16px 24px;\n  background:rgba(13,20,33,0.8);\n  border-bottom:1px solid var(--border);\n  backdrop-filter:blur(12px);\n  position:sticky;top:0;z-index:100;\n}\n.hdr-left{display:flex;align-items:center;gap:12px}\n.hdr-logo{font-size:1.1rem;font-weight:800;letter-spacing:-.02em;color:var(--txt)}\n.hdr-logo span{color:var(--blue)}\n.live-badge{\n  display:flex;align-items:center;gap:6px;\n  background:rgba(0,217,126,0.08);border:1px solid rgba(0,217,126,0.2);\n  border-radius:20px;padding:3px 10px;font-size:.72rem;color:var(--green);font-weight:600;\n}\n.live-dot{width:6px;height:6px;background:var(--green);border-radius:50%;animation:pulse 2s infinite}\n@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.8)}}\n.hdr-right{display:flex;align-items:center;gap:8px;font-size:.78rem;color:var(--muted)}\n.refresh-ts{font-variant-numeric:tabular-nums}\n\n/* 芒聰聙芒聰聙 MAIN GRID 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙 */\n.wrap{padding:20px 24px;max-width:1400px;margin:0 auto}\n\n/* 芒聰聙芒聰聙 KPI ROW 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙 */\n.kpi-grid{\n  display:grid;\n  grid-template-columns:2fr 1.4fr 1.2fr 1fr;\n  gap:12px;margin-bottom:14px;\n}\n@media(max-width:900px){.kpi-grid{grid-template-columns:1fr 1fr;}}\n@media(max-width:500px){.kpi-grid{grid-template-columns:1fr;}}\n\n.card{\n  background:var(--card);border:1px solid var(--border);border-radius:14px;\n  padding:18px 20px;position:relative;overflow:hidden;\n  transition:border-color .2s,box-shadow .2s;\n}\n.card:hover{border-color:var(--border2);box-shadow:0 4px 24px rgba(0,0,0,.3)}\n.card::before{content:\"\";position:absolute;inset:0;border-radius:14px;opacity:0;transition:opacity .3s;pointer-events:none}\n.card.accent-green::before{background:var(--glow-green)}\n.card.accent-blue::before{background:var(--glow-blue)}\n.card:hover::before{opacity:1}\n\n.kpi-label{font-size:.68rem;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:8px;display:flex;align-items:center;gap:6px}\n.kpi-label .tt-icon{color:var(--muted2);cursor:help;font-size:.7rem}\n.kpi-val{font-size:2.2rem;font-weight:800;line-height:1;letter-spacing:-.03em;margin-bottom:6px}\n.kpi-sub{font-size:.78rem;color:var(--muted);display:flex;align-items:center;gap:8px;flex-wrap:wrap}\n.kpi-sub .badge{padding:2px 7px;border-radius:5px;font-size:.68rem;font-weight:700;letter-spacing:.04em}\n\n/* BTC price card special */\n.price-card .kpi-val{font-size:2.6rem}\n.price-delta{font-size:1rem;font-weight:700;margin-left:8px}\n\n/* 芒聰聙芒聰聙 RANGE BAR 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙 */\n.range-bar-wrap{\n  margin-top:12px;\n  background:var(--card);border:1px solid var(--border);border-radius:14px;\n  padding:14px 20px 12px;margin-bottom:14px;\n}\n.range-lbl{font-size:.68rem;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:10px}\n.range-bar{position:relative;height:6px;background:var(--bg2);border-radius:3px;margin:0 6px}\n.range-fill{\n  position:absolute;left:0;top:0;height:100%;\n  background:linear-gradient(90deg,var(--blue),var(--cyan));\n  border-radius:3px;\n}\n.range-thumb{\n  position:absolute;top:50%;transform:translate(-50%,-50%);\n  width:14px;height:14px;background:var(--txt);border-radius:50%;\n  border:2px solid var(--bg);\n  box-shadow:0 0 8px rgba(255,255,255,.3);\n}\n.range-labels{display:flex;justify-content:space-between;margin-top:8px;font-size:.75rem;color:var(--muted2)}\n.range-labels .hi{color:var(--green)}.range-labels .lo{color:var(--red)}\n.range-meta{display:flex;gap:16px;margin-top:10px;font-size:.75rem;color:var(--muted);flex-wrap:wrap}\n.range-meta span{display:flex;align-items:center;gap:4px}\n.range-meta .dot{width:6px;height:6px;border-radius:50%;background:var(--muted2)}\n\n/* 芒聰聙芒聰聙 SIGNAL + CONFIDENCE 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙 */\n.mid-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:14px}\n@media(max-width:700px){.mid-grid{grid-template-columns:1fr}}\n\n/* Confidence gauge */\n.gauge-wrap{display:flex;flex-direction:column;align-items:center;padding:20px 16px 16px}\n.gauge{position:relative;width:130px;height:70px;margin:0 auto 10px}\n.gauge svg{overflow:visible}\n.gauge-bg{stroke:var(--border2);stroke-width:10;fill:none}\n.gauge-fill{stroke-width:10;fill:none;stroke-linecap:round;transform-origin:center;transition:stroke-dashoffset 1s ease}\n.gauge-val{position:absolute;bottom:0;left:50%;transform:translateX(-50%);font-size:1.4rem;font-weight:800;text-align:center;line-height:1}\n.gauge-sub{font-size:.7rem;color:var(--muted);text-align:center;margin-top:4px}\n\n/* Signal direction big display */\n.sig-dir-big{\n  display:flex;flex-direction:column;align-items:center;justify-content:center;\n  padding:20px;text-align:center;\n}\n.sig-dir-icon{font-size:3rem;line-height:1;margin-bottom:8px;filter:drop-shadow(0 0 20px currentColor)}\n.sig-dir-txt{font-size:1.6rem;font-weight:900;letter-spacing:.08em}\n.sig-dir-meta{font-size:.75rem;color:var(--muted);margin-top:6px}\n\n/* Hit rate */\n.hit-wrap{display:flex;flex-direction:column;align-items:center;padding:20px 16px 16px}\n.hit-ring{position:relative;width:90px;height:90px;margin-bottom:10px}\n.hit-ring svg{transform:rotate(-90deg)}\n.hit-ring-bg{fill:none;stroke:var(--border2);stroke-width:8}\n.hit-ring-fill{fill:none;stroke-width:8;stroke-linecap:round;transition:stroke-dasharray 1.2s ease}\n.hit-val{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:1.1rem;font-weight:800}\n.hit-sub{font-size:.73rem;color:var(--muted);text-align:center}\n\n/* 芒聰聙芒聰聙 SIGNAL HISTORY 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙 */\n.section-hdr{font-size:.8rem;font-weight:700;color:var(--muted2);text-transform:uppercase;letter-spacing:.08em;margin-bottom:10px;display:flex;align-items:center;gap:8px}\n.section-hdr::after{content:\"\";flex:1;height:1px;background:var(--border)}\ntable{width:100%;border-collapse:collapse;background:var(--card);border:1px solid var(--border);border-radius:14px;overflow:hidden;margin-bottom:14px}\nthead{background:var(--bg2)}\nth{padding:10px 14px;text-align:left;font-size:.68rem;color:var(--muted);text-transform:uppercase;letter-spacing:.07em;font-weight:600;white-space:nowrap}\ntd{padding:10px 14px;border-top:1px solid var(--border);font-size:.82rem;vertical-align:middle}\n.sig-row{transition:background .15s}\n.sig-row:hover{background:rgba(255,255,255,.03)}\n.ts-cell{color:var(--muted2);font-size:.75rem;font-variant-numeric:tabular-nums}\n.mono{font-variant-numeric:tabular-nums}\n.dir-badge{padding:3px 9px;border-radius:6px;font-size:.75rem;font-weight:700;letter-spacing:.06em;display:inline-flex;align-items:center;gap:4px}\n.conf-pill{position:relative;background:var(--bg2);border-radius:4px;height:18px;width:80px;overflow:hidden}\n.conf-fill{position:absolute;left:0;top:0;height:100%;border-radius:4px;opacity:.7;transition:width .6s ease}\n.conf-num{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:.7rem;font-weight:600;z-index:1}\n.rsi-cell{font-variant-numeric:tabular-nums}\n.empty-row{text-align:center;color:var(--muted);padding:32px;font-style:italic}\n\n/* 芒聰聙芒聰聙 TOOLTIPS 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙 */\n.tooltip-wrap{position:relative;cursor:help;border-bottom:1px dashed var(--border2)}\n.tooltip-wrap .tt{\n  display:none;position:absolute;bottom:calc(100%+6px);left:50%;transform:translateX(-50%);\n  background:#1e293b;border:1px solid var(--border2);border-radius:8px;\n  padding:8px 12px;font-size:.72rem;color:var(--txt);white-space:nowrap;\n  z-index:999;box-shadow:0 4px 16px rgba(0,0,0,.5);pointer-events:none;\n  max-width:240px;white-space:normal;line-height:1.4;\n}\n.tooltip-wrap:hover .tt{display:block}\n\n/* 芒聰聙芒聰聙 STAT PILLS ROW 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙 */\n.stats-row{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:14px}\n.stat-pill{\n  background:var(--card);border:1px solid var(--border);border-radius:10px;\n  padding:10px 16px;display:flex;flex-direction:column;gap:3px;flex:1;min-width:120px;\n}\n.stat-pill .sp-lbl{font-size:.65rem;color:var(--muted);text-transform:uppercase;letter-spacing:.07em}\n.stat-pill .sp-val{font-size:.95rem;font-weight:700;font-variant-numeric:tabular-nums}\n\n/* 芒聰聙芒聰聙 FOOTER 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙 */\n.footer{\n  text-align:center;font-size:.72rem;color:var(--muted);\n  padding:16px 24px;border-top:1px solid var(--border);\n  background:rgba(7,11,20,.6);margin-top:8px;\n}\n.footer a{color:var(--blue);text-decoration:none}\n.footer a:hover{text-decoration:underline}\n\n/* 芒聰聙芒聰聙 ANIMATIONS 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙 */\n@keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}\n.card,.kpi-grid\u003e*,.mid-grid\u003e*{animation:fadeUp .4s ease both}\n.kpi-grid\u003e*:nth-child(1){animation-delay:.05s}\n.kpi-grid\u003e*:nth-child(2){animation-delay:.1s}\n.kpi-grid\u003e*:nth-child(3){animation-delay:.15s}\n.kpi-grid\u003e*:nth-child(4){animation-delay:.2s}\n.mid-grid\u003e*:nth-child(1){animation-delay:.25s}\n.mid-grid\u003e*:nth-child(2){animation-delay:.3s}\n.mid-grid\u003e*:nth-child(3){animation-delay:.35s}\n\n/* Glow on price */\n.price-glow{\n  position:absolute;top:-20px;right:-20px;\n  width:120px;height:120px;border-radius:50%;\n  filter:blur(40px);opacity:.15;pointer-events:none;\n}\n\u003c/style\u003e\n\u003c/head\u003e\n\u003cbody\u003e\n\n\u003c!-- HEADER --\u003e\n\u003cdiv class=\"hdr\"\u003e\n  \u003cdiv class=\"hdr-left\"\u003e\n    \u003cdiv class=\"hdr-logo\"\u003e\u0026#x1F916; Crypto \u003cspan\u003eSpecialist\u003c/span\u003e v3\u003c/div\u003e\n    \u003cdiv class=\"live-badge\"\u003e\u003cspan class=\"live-dot\"\u003e\u003c/span\u003e LIVE\u003c/div\u003e\n  \u003c/div\u003e\n  \u003cdiv class=\"hdr-right\"\u003e\n    \u003cspan class=\"refresh-ts\"\u003e${new Date().toISOString().slice(0,16).replace(\u0027T\u0027,\u0027 \u0027)} UTC\u003c/span\u003e\n    \u0026nbsp;脗路\u0026nbsp; Auto-refresh 5min\n    \u0026nbsp;脗路\u0026nbsp; \u003cspan style=\"color:var(--green)\"\u003ePAPER MODE\u003c/span\u003e\n  \u003c/div\u003e\n\u003c/div\u003e\n\n\u003cdiv class=\"wrap\"\u003e\n\n\u003c!-- 芒聰聙芒聰聙 KPI ROW 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙 --\u003e\n\u003cdiv class=\"kpi-grid\"\u003e\n\n  \u003c!-- BTC Price --\u003e\n  \u003cdiv class=\"card price-card ${change24h \u003e= 0 ? \u0027accent-green\u0027 : \u0027\u0027}\"\u003e\n    \u003cdiv class=\"price-glow\" style=\"background:${pCol}\"\u003e\u003c/div\u003e\n    \u003cdiv class=\"kpi-label\"\u003e\n      \u003cspan class=\"tooltip-wrap\"\u003eBTC / USD\u003cspan class=\"tt\"\u003eBitcoin price in US Dollars. Last trade from Kraken spot exchange.\u003c/span\u003e\u003c/span\u003e\n    \u003c/div\u003e\n    \u003cdiv class=\"kpi-val\" style=\"color:${pCol}\"\u003e${\u0027$\u0027+fmt(price)} \u003cspan class=\"price-delta\" style=\"color:${pCol}\"\u003e${c24Str}\u003c/span\u003e\u003c/div\u003e\n    \u003cdiv class=\"kpi-sub\"\u003e\n      \u003cspan\u003eOpen $${fmt(openDay)}\u003c/span\u003e\n      \u003cspan\u003e\u0026middot;\u003c/span\u003e\n      \u003cspan\u003eVWAP $${fmt(vwap24)}\u003c/span\u003e\n      \u003cspan\u003e\u0026middot;\u003c/span\u003e\n      \u003cspan class=\"badge\" style=\"background:${change24h\u003e=0?\u0027rgba(0,217,126,.1)\u0027:\u0027rgba(255,77,109,.1)\u0027};color:${pCol}\"\u003e24H\u003c/span\u003e\n    \u003c/div\u003e\n  \u003c/div\u003e\n\n  \u003c!-- Signal --\u003e\n  \u003cdiv class=\"card\"\u003e\n    \u003cdiv class=\"kpi-label\"\u003e\n      \u003cspan class=\"tooltip-wrap\"\u003eCurrent Signal\u003cspan class=\"tt\"\u003eLatest direction output from the 10-strategy quorum gate. WAIT = below 60% confidence threshold or quorum \u0026lt; 3 families.\u003c/span\u003e\u003c/span\u003e\n    \u003c/div\u003e\n    \u003cdiv class=\"kpi-val\" style=\"font-size:1.8rem;color:${dCol(last.dir||\u0027WAIT\u0027)}\"\u003e${dIcon(last.dir||\u0027WAIT\u0027)} ${last.dir||\u0027WAIT\u0027}\u003c/div\u003e\n    \u003cdiv class=\"kpi-sub\"\u003e\n      \u003cspan\u003eConf: \u003cstrong style=\"color:${dCol(last.dir||\u0027WAIT\u0027)}\"\u003e${last.conf||\u0027?\u0027}%\u003c/strong\u003e\u003c/span\u003e\n      \u0026nbsp;脗路\u0026nbsp;\n      \u003cspan\u003e${last.ts||\u0027芒聙聰\u0027} UTC\u003c/span\u003e\n    \u003c/div\u003e\n  \u003c/div\u003e\n\n  \u003c!-- Hit Rate --\u003e\n  \u003cdiv class=\"card\"\u003e\n    \u003cdiv class=\"kpi-label\"\u003e\n      \u003cspan class=\"tooltip-wrap\"\u003eHit Rate\u003cspan class=\"tt\"\u003e% of BUY/SELL signals where price moved in the correct direction (\u003e0.3% threshold). Target: 芒聣楼55% to enable live trading.\u003c/span\u003e\u003c/span\u003e\n    \u003c/div\u003e\n    \u003cdiv class=\"kpi-val\" style=\"color:${hCol}\"\u003e${hitRate \u003e= 0 ? hitRate+\u0027%\u0027 : \u0027N/A\u0027}\u003c/div\u003e\n    \u003cdiv class=\"kpi-sub\"\u003e\n      ${hitTotal \u003e 0\n        ? `\u003cspan style=\"color:var(--green)\"\u003e${hitCorrect}W\u003c/span\u003e / \u003cspan style=\"color:var(--red)\"\u003e${hitIncorrect}L\u003c/span\u003e of ${hitTotal}`\n        : \u0027\u003cspan style=\"font-style:italic\"\u003eAccumulating data...\u003c/span\u003e\u0027}\n      ${hitTotal \u003e 0 \u0026\u0026 hitAvgConf \u003e 0 ? `\u0026nbsp;脗路\u0026nbsp; Avg conf ${hitAvgConf}%` : \u0027\u0027}\n    \u003c/div\u003e\n  \u003c/div\u003e\n\n  \u003c!-- Regime --\u003e\n  \u003cdiv class=\"card\"\u003e\n    \u003cdiv class=\"kpi-label\"\u003e\n      \u003cspan class=\"tooltip-wrap\"\u003eMarket Regime\u003cspan class=\"tt\"\u003eClassified from Hurst exponent, volatility, and trend strength. Drives strategy selection and confidence multipliers.\u003c/span\u003e\u003c/span\u003e\n    \u003c/div\u003e\n    \u003cdiv class=\"kpi-val\" style=\"font-size:1rem;margin-top:6px;line-height:1.4\"\u003e${regLabel(last.reg||\u0027\u0027)}\u003c/div\u003e\n    \u003cdiv class=\"kpi-sub\"\u003e\n      ${last.quor \u0026\u0026 last.quor !== \u0027?\u0027 ? `Quorum: \u003cstrong\u003e${last.quor}/10\u003c/strong\u003e` : \u0027Regime classification\u0027}\n    \u003c/div\u003e\n  \u003c/div\u003e\n\u003c/div\u003e\n\n\u003c!-- 芒聰聙芒聰聙 RANGE BAR 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙 --\u003e\n\u003cdiv class=\"range-bar-wrap card\"\u003e\n  \u003cdiv class=\"range-lbl\"\u003e\n    \u003cspan class=\"tooltip-wrap\"\u003e24H Price Range\u003cspan class=\"tt\"\u003eHigh and low prices over the past 24 hours. The marker shows where the current price sits within today\u0027s range.\u003c/span\u003e\u003c/span\u003e\n  \u003c/div\u003e\n  \u003cdiv class=\"range-bar\"\u003e\n    \u003cdiv class=\"range-fill\" style=\"width:${rangePos}%\"\u003e\u003c/div\u003e\n    \u003cdiv class=\"range-thumb\" style=\"left:${rangePos}%\"\u003e\u003c/div\u003e\n  \u003c/div\u003e\n  \u003cdiv class=\"range-labels\"\u003e\n    \u003cspan class=\"lo\"\u003eLow $${fmt(low24)}\u003c/span\u003e\n    \u003cspan style=\"color:var(--muted2)\"\u003eCurrent $${fmt(price)} \u0026nbsp; (${rangePos}% of range)\u003c/span\u003e\n    \u003cspan class=\"hi\"\u003eHigh $${fmt(high24)}\u003c/span\u003e\n  \u003c/div\u003e\n  \u003cdiv class=\"range-meta\"\u003e\n    \u003cspan\u003e\u003cspan class=\"dot\"\u003e\u003c/span\u003e Vol 24H: \u003cstrong\u003e$${vol24usd}M\u003c/strong\u003e\u003c/span\u003e\n    \u003cspan\u003e\u003cspan class=\"dot\"\u003e\u003c/span\u003e Trades: \u003cstrong\u003e${fmtK(trades24)}\u003c/strong\u003e\u003c/span\u003e\n    \u003cspan\u003e\u003cspan class=\"dot\"\u003e\u003c/span\u003e Spread: \u003cstrong\u003e$${spread}\u003c/strong\u003e\u003c/span\u003e\n    \u003cspan\u003e\u003cspan class=\"dot\"\u003e\u003c/span\u003e Bid: \u003cstrong\u003e$${fmt(bid)}\u003c/strong\u003e\u003c/span\u003e\n    \u003cspan\u003e\u003cspan class=\"dot\"\u003e\u003c/span\u003e Ask: \u003cstrong\u003e$${fmt(ask)}\u003c/strong\u003e\u003c/span\u003e\n  \u003c/div\u003e\n\u003c/div\u003e\n\n\u003c!-- 芒聰聙芒聰聙 CONFIDENCE / DIRECTION / HIT RATE 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙 --\u003e\n\u003cdiv class=\"mid-grid\"\u003e\n\n  \u003c!-- Direction \u0026 Quorum --\u003e\n  \u003cdiv class=\"card\"\u003e\n    \u003cdiv class=\"kpi-label\"\u003eSignal Direction \u0026amp; Momentum\u003c/div\u003e\n    \u003cdiv class=\"sig-dir-big\"\u003e\n      \u003cdiv class=\"sig-dir-icon\" style=\"color:${dCol(last.dir||\u0027WAIT\u0027)}\"\u003e${dIcon(last.dir||\u0027WAIT\u0027)}\u003c/div\u003e\n      \u003cdiv class=\"sig-dir-txt\" style=\"color:${dCol(last.dir||\u0027WAIT\u0027)}\"\u003e${last.dir||\u0027WAIT\u0027}\u003c/div\u003e\n      \u003cdiv class=\"sig-dir-meta\"\u003e\n        ${last.rsi \u0026\u0026 last.rsi !== \u0027?\u0027 ? `RSI: ${last.rsi} \u0026nbsp;脗路\u0026nbsp;` : \u0027\u0027}\n        ${last.nts \u0026\u0026 last.nts !== \u0027?\u0027 ? `No-Trade: ${last.nts}%` : \u0027\u0027}\n      \u003c/div\u003e\n    \u003c/div\u003e\n    \u003cdiv class=\"stats-row\" style=\"margin-top:8px;margin-bottom:0\"\u003e\n      \u003cdiv class=\"stat-pill\"\u003e\u003cdiv class=\"sp-lbl\"\u003eBUY signals\u003c/div\u003e\u003cdiv class=\"sp-val\" style=\"color:var(--green)\"\u003e${buyCnt}\u003c/div\u003e\u003c/div\u003e\n      \u003cdiv class=\"stat-pill\"\u003e\u003cdiv class=\"sp-lbl\"\u003eSELL signals\u003c/div\u003e\u003cdiv class=\"sp-val\" style=\"color:var(--red)\"\u003e${sellCnt}\u003c/div\u003e\u003c/div\u003e\n      \u003cdiv class=\"stat-pill\"\u003e\u003cdiv class=\"sp-lbl\"\u003eWAIT signals\u003c/div\u003e\u003cdiv class=\"sp-val\" style=\"color:var(--muted2)\"\u003e${waitCnt}\u003c/div\u003e\u003c/div\u003e\n    \u003c/div\u003e\n  \u003c/div\u003e\n\n  \u003c!-- Confidence Gauge --\u003e\n  \u003cdiv class=\"card\"\u003e\n    \u003cdiv class=\"kpi-label\"\u003e\n      \u003cspan class=\"tooltip-wrap\"\u003eSignal Confidence\u003cspan class=\"tt\"\u003eLogistic-scaled score from raw strategy scores, adjusted for regime, R:R ratio, news sentiment, quorum, and confidence decay. Minimum 60% required to act.\u003c/span\u003e\u003c/span\u003e\n    \u003c/div\u003e\n    \u003cdiv class=\"gauge-wrap\"\u003e\n      \u003cdiv class=\"gauge\"\u003e\n        \u003csvg viewBox=\"0 0 130 70\" width=\"130\" height=\"70\"\u003e\n          \u003c!-- background arc (semicircle) --\u003e\n          \u003cpath d=\"M 15 65 A 50 50 0 0 1 115 65\" class=\"gauge-bg\" stroke=\"var(--border2)\" stroke-width=\"10\" fill=\"none\" stroke-linecap=\"round\"/\u003e\n          \u003c!-- fill arc --\u003e\n          \u003cpath d=\"M 15 65 A 50 50 0 0 1 115 65\"\n            class=\"gauge-fill\"\n            stroke=\"${confNum \u003e= 60 ? dCol(last.dir||\u0027WAIT\u0027) : \u0027var(--muted)\u0027}\"\n            fill=\"none\"\n            stroke-linecap=\"round\"\n            stroke-dasharray=\"${Math.round(confNum * 1.57)} 157\"\n          /\u003e\n        \u003c/svg\u003e\n        \u003cdiv class=\"gauge-val\" style=\"color:${confNum \u003e= 60 ? dCol(last.dir||\u0027WAIT\u0027) : \u0027var(--muted2)\u0027}\"\u003e${last.conf||\u0027?\u0027}%\u003c/div\u003e\n      \u003c/div\u003e\n      \u003cdiv class=\"gauge-sub\"\u003eMin to trade: \u003cstrong style=\"color:var(--yellow)\"\u003e60%\u003c/strong\u003e\u003c/div\u003e\n      \u003cdiv style=\"margin-top:10px;font-size:.75rem;color:var(--muted);text-align:center\"\u003e\n        ${confNum \u003e= 60\n          ? \u0027\u003cspan style=\"color:var(--green)\"\u003e芒聹聯 Above threshold 芒聙聰 signal active\u003c/span\u003e\u0027\n          : confNum \u003e 0\n            ? \u0027\u003cspan style=\"color:var(--red)\"\u003e芒聹聴 Below threshold 芒聙聰 WAIT forced\u003c/span\u003e\u0027\n            : \u0027\u003cspan style=\"color:var(--muted2)\"\u003eAwaiting signal...\u003c/span\u003e\u0027}\n      \u003c/div\u003e\n    \u003c/div\u003e\n  \u003c/div\u003e\n\n  \u003c!-- Hit Rate Ring --\u003e\n  \u003cdiv class=\"card\"\u003e\n    \u003cdiv class=\"kpi-label\"\u003e\n      \u003cspan class=\"tooltip-wrap\"\u003ePerformance Ring\u003cspan class=\"tt\"\u003eCalculated every 4 hours by Outcome Tracker. Needs 芒聣楼55% hit rate for live trading to unlock.\u003c/span\u003e\u003c/span\u003e\n    \u003c/div\u003e\n    \u003cdiv class=\"hit-wrap\"\u003e\n      \u003cdiv class=\"hit-ring\"\u003e\n        \u003csvg viewBox=\"0 0 90 90\" width=\"90\" height=\"90\"\u003e\n          \u003ccircle cx=\"45\" cy=\"45\" r=\"37\" class=\"hit-ring-bg\"/\u003e\n          \u003ccircle cx=\"45\" cy=\"45\" r=\"37\"\n            class=\"hit-ring-fill\"\n            stroke=\"${hCol}\"\n            stroke-dasharray=\"${hitRate \u003e= 0 ? Math.round(hitRate * 2.325) + \u0027 232.5\u0027 : \u00270 232.5\u0027}\"\n          /\u003e\n        \u003c/svg\u003e\n        \u003cdiv class=\"hit-val\" style=\"color:${hCol}\"\u003e${hitRate \u003e= 0 ? hitRate+\u0027%\u0027 : \u0027N/A\u0027}\u003c/div\u003e\n      \u003c/div\u003e\n      \u003cdiv class=\"hit-sub\"\u003e\n        ${hitTotal \u003e 0\n          ? `\u003cspan style=\"color:var(--green)\"\u003e${hitCorrect} correct\u003c/span\u003e / \u003cspan style=\"color:var(--red)\"\u003e${hitIncorrect} wrong\u003c/span\u003e\u003cbr\u003eof ${hitTotal} evaluated trades`\n          : \u0027Outcome Tracker runs every 4h\u0027}\n        \u003cbr\u003e\u003cbr\u003e\n        \u003cspan style=\"color:var(--yellow)\"\u003eTarget: 55%+\u003c/span\u003e\n        ${hitRate \u003e= 55 ? \u0027\u0026nbsp;\u003cspan style=\"color:var(--green)\"\u003e芒聹聯 UNLOCKED\u003c/span\u003e\u0027 : \u0027\u0027}\n      \u003c/div\u003e\n    \u003c/div\u003e\n  \u003c/div\u003e\n\u003c/div\u003e\n\n\u003c!-- 芒聰聙芒聰聙 SIGNAL HISTORY 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙 --\u003e\n\u003cdiv class=\"section-hdr\"\u003eSignal History (last 10)\u003c/div\u003e\n\u003ctable\u003e\n\u003cthead\u003e\n  \u003ctr\u003e\n    \u003cth\u003e\u003cspan class=\"tooltip-wrap\"\u003eTime UTC\u003cspan class=\"tt\"\u003eTime of the 5-minute scan cycle that produced this signal.\u003c/span\u003e\u003c/span\u003e\u003c/th\u003e\n    \u003cth\u003e\u003cspan class=\"tooltip-wrap\"\u003eDirection\u003cspan class=\"tt\"\u003eBUY/SELL = quorum of 芒聣楼3 strategy families agreed and confidence 芒聣楼60%. WAIT = below threshold.\u003c/span\u003e\u003c/span\u003e\u003c/th\u003e\n    \u003cth\u003e\u003cspan class=\"tooltip-wrap\"\u003eBTC Price\u003cspan class=\"tt\"\u003eBitcoin price at the time this signal was generated.\u003c/span\u003e\u003c/span\u003e\u003c/th\u003e\n    \u003cth\u003e\u003cspan class=\"tooltip-wrap\"\u003eConfidence\u003cspan class=\"tt\"\u003eFinal confidence score after logistic scaling, regime adjustment, news sentiment, R:R ratio, and decay factor.\u003c/span\u003e\u003c/span\u003e\u003c/th\u003e\n    \u003cth\u003e\u003cspan class=\"tooltip-wrap\"\u003eRSI\u003cspan class=\"tt\"\u003eRelative Strength Index from the 1H timeframe. Values below 30 = oversold, above 70 = overbought.\u003c/span\u003e\u003c/span\u003e\u003c/th\u003e\n    \u003cth\u003e\u003cspan class=\"tooltip-wrap\"\u003eRegime\u003cspan class=\"tt\"\u003eMarket regime classification at the time of the signal. BULL_STRONG / BEAR_STRONG = trend following. CHOPPY = caution.\u003c/span\u003e\u003c/span\u003e\u003c/th\u003e\n  \u003c/tr\u003e\n\u003c/thead\u003e\n\u003ctbody\u003e${sigRows}\u003c/tbody\u003e\n\u003c/table\u003e\n\n\u003c!-- 芒聰聙芒聰聙 FOOTER 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙 --\u003e\n\u003c/div\u003e\u003c!-- /wrap --\u003e\n\n\u003cdiv class=\"footer\"\u003e\n  10 strategy families \u0026middot; 4 timeframes (15M/1H/4H/1D) \u0026middot; Claude CLI Pro + DeepSeek AI \u0026middot;\n  Monte Carlo 500 paths \u0026middot; Wyckoff / SMC / Fibonacci / Macro \u0026middot;\n  \u003ca href=\"https://outstanding-blessing-production-1d4b.up.railway.app\" target=\"_blank\"\u003en8n\u003c/a\u003e \u0026middot;\n  \u003ca href=\"https://super-agent-production.up.railway.app/observability\" target=\"_blank\"\u003eObservability\u003c/a\u003e\n  \u0026nbsp;\u0026middot;\u0026nbsp; \u003cstrong style=\"color:var(--yellow)\"\u003ePAPER ONLY\u003c/strong\u003e until hit rate \u0026ge; 55%\n\u003c/div\u003e\n\n\u003cscript\u003e\n// Animate numbers counting up on load\ndocument.querySelectorAll(\u0027.kpi-val\u0027).forEach(el =\u003e {\n  el.style.opacity = \u00270\u0027;\n  setTimeout(() =\u003e { el.style.transition = \u0027opacity .5s\u0027; el.style.opacity = \u00271\u0027; }, 100);\n});\n// Add subtle shimmer to cards on hover\ndocument.querySelectorAll(\u0027.card\u0027).forEach(card =\u003e {\n  card.addEventListener(\u0027mousemove\u0027, e =\u003e {\n    const r = card.getBoundingClientRect();\n    const x = ((e.clientX - r.left) / r.width * 100).toFixed(1);\n    const y = ((e.clientY - r.top) / r.height * 100).toFixed(1);\n    card.style.setProperty(\u0027--mx\u0027, x + \u0027%\u0027);\n    card.style.setProperty(\u0027--my\u0027, y + \u0027%\u0027);\n  });\n});\n\u003c/script\u003e\n\u003c/body\u003e\u003c/html\u003e`;\n\nreturn [{ json: { html } }];\n"
                                                           },
