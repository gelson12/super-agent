                      "id":  "pg-get-finding",
                      "name":  "Get Finding + Context",
                      "type":  "n8n-nodes-base.postgres",
                      "typeVersion":  2.5,
                      "position":  [
                                       460,
                                       300
                                   ],
                      "credentials":  {
