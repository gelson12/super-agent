                  {
                      "parameters":  {
                                         "jsCode":  "const f = $input.first().json;\n\n// ?? Technical Severity (0-10) ??????????????????????????????????\nconst sevScore = { critical: 10, high: 8, medium: 5, low: 2, informational: 0 };\nconst technicalSeverity = sevScore[f.severity] ?? 5;\n\n// ?? Validation Confidence (0-10) ??????????????????????????????\nconst valScore = { validated: 10, analyst_reviewed: 7, scanner_only: 4, pending_analyst: 4, likely_false_positive: 1 };\nconst validationConfidence = valScore[f.validation_status] ?? 4;\n\n// ?? Internet Exposure (0-10) ???????????????????????????????????\nlet internetExposure = 5;\nif (f.scope_status === \u0027in_scope\u0027 \u0026\u0026 f.environment === \u0027production\u0027) internetExposure = 10;\nelse if (f.environment === \u0027staging\u0027) internetExposure = 6;\nelse if (f.environment === \u0027development\u0027) internetExposure = 3;\nif (f.auth_required) internetExposure = Math.max(2, internetExposure - 3);\n\n// ?? Asset Criticality (0-10) ??????????????????????????????????\nconst critScore = { critical: 10, high: 7, medium: 4, low: 1 };\nconst assetCriticality = critScore[f.business_criticality] ?? 4;\n\n// ?? Data Sensitivity (0-10) ???????????????????????????????????\nconst sensitiveCategories = [\u0027injection\u0027,\u0027auth\u0027,\u0027access_control\u0027,\u0027crypto\u0027,\u0027exposure\u0027];\nconst dataSensitivity = sensitiveCategories.includes(f.category) ? 8 : 4;\n\n// ?? Ease of Exploitation (0-10) ???????????????????????????????\nconst easyExploit = [\u0027xss\u0027,\u0027injection\u0027,\u0027config\u0027,\u0027exposure\u0027];\nconst hardExploit = [\u0027ssrf\u0027,\u0027xxe\u0027,\u0027path_traversal\u0027];\nlet easeOfExploitation = 5;\nif (easyExploit.includes(f.category)) easeOfExploitation = 8;\nelse if (hardExploit.includes(f.category)) easeOfExploitation = 3;\n\n// ?? Recurrence Bonus ??????????????????????????????????????????\nconst recurrenceBonus = f.is_recurring ? Math.min(4, (f.recurrence_count || 0) * 2) : 0;\n\n// ?? Breadth (across assets) ???????????????????????????????????\nconst breadthBonus = f.occurrence_count \u003e 5 ? 3 : f.occurrence_count \u003e 2 ? 1 : 0;\n\n// ?? Auth Boundary Bonus ???????????????????????????????????????\nconst authBoundaryBonus = (f.auth_required === false \u0026\u0026 f.category !== \u0027config\u0027) ? 2 : 0;\n\n// ?? Composite Score (0-10 scale) ?????????????????????????????\nconst weighted =\n  technicalSeverity   * 0.20 +\n  validationConfidence * 0.15 +\n  internetExposure    * 0.15 +\n  assetCriticality    * 0.15 +\n  dataSensitivity     * 0.10 +\n  easeOfExploitation  * 0.10;\n\nconst reconScore = Math.min(10, Math.max(0,\n  weighted + (recurrenceBonus * 0.08) + (breadthBonus * 0.07) + authBoundaryBonus\n));\n\nconst roundedScore = Math.round(reconScore * 100) / 100;\n\n// ?? Priority Bucket ???????????????????????????????????????????\nlet priorityBucket;\nif (roundedScore \u003e= 8.5)      priorityBucket = \u0027immediate_attention\u0027;\nelse if (roundedScore \u003e= 7.0) priorityBucket = \u0027high_priority\u0027;\nelse if (roundedScore \u003e= 5.0) priorityBucket = \u0027medium_priority\u0027;\nelse if (roundedScore \u003e= 3.0) priorityBucket = \u0027low_priority\u0027;\nelse if (roundedScore \u003e= 1.0) priorityBucket = \u0027monitor\u0027;\nelse                          priorityBucket = \u0027likely_false_positive\u0027;\n\n// ?? Score Explanation ?????????????????????????????????????????\nconst reasons = [];\nif (technicalSeverity \u003e= 8) reasons.push(`High technical severity (${f.severity})`);\nif (validationConfidence \u003e= 8) reasons.push(\u0027Analyst validated\u0027);\nif (internetExposure \u003e= 8) reasons.push(\u0027Internet-exposed production asset\u0027);\nif (assetCriticality \u003e= 8) reasons.push(`Critical asset (${f.business_criticality} criticality)`);\nif (recurrenceBonus \u003e= 2) reasons.push(`Recurring finding (${f.recurrence_count} prior engagement(s))`);\nif (breadthBonus \u003e 0) reasons.push(`Affects ${f.occurrence_count} assets (breadth)`);\nif (authBoundaryBonus \u003e 0) reasons.push(\u0027No authentication required\u0027);\nif (validationConfidence \u003c= 4) reasons.push(\u0027Confidence capped - pending analyst review\u0027);\n\nconst scoreExplanation = reasons.length \u003e 0\n  ? `Score ${roundedScore}/10 (${priorityBucket.replace(/_/g,\u0027 \u0027)}): ${reasons.join(\u0027; \u0027)}.`\n  : `Score ${roundedScore}/10 (${priorityBucket.replace(/_/g,\u0027 \u0027)})`;\n\nconst scoreBreakdown = {\n  technical_severity: technicalSeverity,\n  validation_confidence: validationConfidence,\n  internet_exposure: internetExposure,\n  asset_criticality: assetCriticality,\n  data_sensitivity: dataSensitivity,\n  ease_of_exploitation: easeOfExploitation,\n  recurrence_bonus: recurrenceBonus,\n  breadth_bonus: breadthBonus,\n  auth_boundary_bonus: authBoundaryBonus\n};\n\nreturn [{ json: {\n  finding_id: f.id,\n  recon_score: roundedScore,\n  priority_bucket: priorityBucket,\n  score_explanation: scoreExplanation,\n  score_breakdown: scoreBreakdown,\n  severity: f.severity,\n  is_immediate: priorityBucket === \u0027immediate_attention\u0027\n} }];"
                                     },
