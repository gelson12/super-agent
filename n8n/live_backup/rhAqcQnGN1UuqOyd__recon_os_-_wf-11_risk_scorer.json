                  {
                      "parameters":  {
                                         "operation":  "executeQuery",
                                         "query":  "SELECT\n  nf.id, nf.title, nf.severity, nf.category, nf.cwe_id, nf.owasp_category,\n  nf.validation_status, nf.is_recurring, nf.recurrence_count, nf.occurrence_count,\n  nf.first_seen,\n  a.business_criticality, a.scope_status, a.environment, a.auth_required, a.asset_type,\n  e.rate_limit_profile,\n  c.industry\nFROM normalized_findings nf\nJOIN assets a ON nf.asset_id = a.id\nJOIN engagements e ON nf.engagement_id = e.id\nJOIN clients c ON e.client_id = c.id\nWHERE nf.id = \u0027{{ ($input.first().json.body || $input.first().json).finding_id }}\u0027",
