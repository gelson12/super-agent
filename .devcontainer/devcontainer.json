{
  "name": "Super Agent Dev",
  "image": "gelson12/super-agent:latest",
  "customizations": {
    "vscode": {
      "extensions": [
        "Dart-Code.dart-code",
        "Dart-Code.flutter",
        "GitHub.vscode-pull-request-github",
        "eamodio.gitlens",
        "Anthropic.claude-code"
      ],
      "settings": {
        "dart.flutterSdkPath": "/opt/flutter",
        "dart.sdkPath": "/opt/flutter/bin/cache/dart-sdk",
        "editor.formatOnSave": true,
        "editor.fontSize": 14,
        "editor.fontFamily": "'Fira Code', 'Cascadia Code', monospace",
        "editor.fontLigatures": true,
        "workbench.colorTheme": "Abyss",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "remoteEnv": {
    "ANDROID_HOME": "/opt/android-sdk",
    "ANDROID_SDK_ROOT": "/opt/android-sdk",
    "FLUTTER_HOME": "/opt/flutter",
    "JAVA_HOME": "/usr/lib/jvm/java-17-openjdk-amd64",
    "PATH": "/opt/flutter/bin:/opt/android-sdk/cmdline-tools/latest/bin:/opt/android-sdk/platform-tools:${containerEnv:PATH}"
  },
  "postCreateCommand": "flutter doctor && echo 'Dev container ready.'",
  "forwardPorts": [8000, 3001]
}
