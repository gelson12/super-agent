# Legion Engineer — env template. Real values live in Railway env vars.
# DO NOT commit a populated .env. This file only lists variable *names*.

# ── Feature flags ────────────────────────────────────────────────
LEGION_ENABLED=false
L5_ENABLED=false
HIVE_EARLY_TERMINATION=true
HF_ENABLED=false
OLLAMA_ENABLED=false
KIMI_ENABLED=false
DUAL_ACCOUNT_ENABLED=false
GEMINI_B_ENABLED=false
CHATGPT_ENABLED=false

# ── Shared secrets ───────────────────────────────────────────────
LEGION_API_SHARED_SECRET=
PRIMARY_BEACON_SECRET=

# ── Infrastructure ───────────────────────────────────────────────
PG_DSN=
PRIMARY_HEALTH_URL=http://inspiring-cat:8003/auth/login-status
PRIMARY_PROBE_TIMEOUT_S=1.5

# ── Claude Account B (Legion-owned) ──────────────────────────────
CLAUDE_ACCOUNT_B_EMAIL=
CLAUDE_ACCOUNT_B_SESSION_TOKEN=
CLAUDE_ACCOUNT_B_REFRESH_TOKEN=

# ── ChatGPT (OpenAI Chat Completions API) ────────────────────────
# CHATGPT_ACCOUNT_EMAIL is a telemetry label. Actual auth is OPENAI_API_KEY.
CHATGPT_ACCOUNT_EMAIL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ── Kimi (CLI subscription — NOT API key) ───────────────────────
# Kimi uses the CLI subscription tied to KIMI_ACCOUNT_EMAIL, not an API key.
# KIMI_SESSION_TOKEN is a base64-encoded tar.gz of the credentials dir the
# `kimi` CLI writes to ~/.kimi/ after a successful login.
# Capture via /app/scripts/capture_cli_creds.sh kimi.
KIMI_ENABLED=false
KIMI_ACCOUNT_EMAIL=
KIMI_SESSION_TOKEN=
# Legacy: left in case you want to use the Moonshot API key path instead of
# CLI subscription. Prefer KIMI_SESSION_TOKEN above.
KIMI_API_KEY=

# ── Ollama (optional remote) ─────────────────────────────────────
OLLAMA_API_KEY=

# ── Gemini Account B ─────────────────────────────────────────────
GEMINI_ACCOUNT_B_EMAIL=
GEMINI_API_KEY_B=

# ── Hugging Face ─────────────────────────────────────────────────
HF_API_KEY=
HF_COST_CAP_USD=2

# ── Suitability classifier (Haiku) ───────────────────────────────
ANTHROPIC_API_KEY_HAIKU_CLASSIFIER=

# ── n8n magic-link webhook (shared with inspiring-cat) ───────────
N8N_MAGIC_LINK_WEBHOOK=

# ── Rate-limit defaults ──────────────────────────────────────────
CLAUDE_B_RPM=40
KIMI_RPM=60
GEMINI_B_RPM=15
HF_RPM=1000
