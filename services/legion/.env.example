# Legion Engineer — env template. Real values live in Railway env vars.
# DO NOT commit a populated .env. This file only lists variable *names*.

# ── Feature flags ────────────────────────────────────────────────
LEGION_ENABLED=false
L5_ENABLED=false
HIVE_EARLY_TERMINATION=true
HF_ENABLED=false
OLLAMA_ENABLED=false
KIMI_ENABLED=false
DUAL_ACCOUNT_ENABLED=false
GEMINI_B_ENABLED=false
CHATGPT_ENABLED=false

# ── Shared secrets ───────────────────────────────────────────────
LEGION_API_SHARED_SECRET=
PRIMARY_BEACON_SECRET=

# ── Infrastructure ───────────────────────────────────────────────
PG_DSN=
PRIMARY_HEALTH_URL=http://inspiring-cat:8003/auth/login-status
PRIMARY_PROBE_TIMEOUT_S=1.5

# ── Claude Account B (Legion-owned) ──────────────────────────────
CLAUDE_ACCOUNT_B_EMAIL=
CLAUDE_ACCOUNT_B_SESSION_TOKEN=
CLAUDE_ACCOUNT_B_REFRESH_TOKEN=

# ── ChatGPT (OpenAI Chat Completions API) ────────────────────────
# CHATGPT_ACCOUNT_EMAIL is a telemetry label. Actual auth is OPENAI_API_KEY.
CHATGPT_ACCOUNT_EMAIL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ── Kimi: REMOVED 2026-04-24 — Moonshot moved Kimi CLI to paid-only
# (402 on `kimi login`). Code removed from hive registry. If Moonshot ever
# reinstates a free tier or you buy a Coding Plan, restore the agent from
# commits 4d70f93 (CLI install) + 2c55033 (agent code).

# ── Ollama (optional remote) ─────────────────────────────────────
OLLAMA_API_KEY=

# ── Gemini Account B ─────────────────────────────────────────────
GEMINI_ACCOUNT_B_EMAIL=
GEMINI_API_KEY_B=

# ── Hugging Face ─────────────────────────────────────────────────
HF_API_KEY=
HF_COST_CAP_USD=2

# ── Suitability classifier (Haiku) ───────────────────────────────
ANTHROPIC_API_KEY_HAIKU_CLASSIFIER=

# ── Groq (free-tier API, no credit card; OpenAI-compatible) ────
# Get a key at https://console.groq.com/keys (free signup).
# Default model is llama-3.3-70b-versatile; override via GROQ_MODEL.
GROQ_ENABLED=false
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── OpenRouter (free models via :free suffix, no credit card) ──
# Key: https://openrouter.ai/keys
# Default points at a free Llama-3.1-8b. Browse free options at
# https://openrouter.ai/models?q=free
OPENROUTER_ENABLED=false
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-3-4b-it:free
OPENROUTER_REFERER=https://legion-production-36db.up.railway.app
OPENROUTER_APP_TITLE=Legion Engineer

# ── Cerebras Cloud (~2000 tok/s Llama, free tier) ──────────────
# Key: https://cloud.cerebras.ai (free signup, no credit card)
# Verified free-tier model IDs (2026-04-25): llama3.1-8b, gpt-oss-120b,
# qwen-3-235b-a22b-instruct-2507, zai-glm-4.7. Run
# scripts/probe_cerebras_models.sh inside the container to refresh.
CEREBRAS_ENABLED=false
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama3.1-8b

# ── GitHub Models (free GPT-4o-mini, Llama, Phi, etc.) ─────────
# PAT (fine-grained) with scope `models:read`, or any classic PAT works.
# Key: https://github.com/settings/personal-access-tokens
# Models are namespaced: openai/gpt-4o-mini, meta/Llama-3.3-70B-Instruct,
# microsoft/Phi-3.5-MoE-instruct, mistral-ai/Mistral-large-2411, etc.
GITHUB_MODELS_ENABLED=false
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_MODEL=openai/gpt-4o-mini

# ── Shared memory bridge to super-agent ──────────────────────────
# Hive prepends top-K relevant memories from super-agent's /memory/search
# to every query so all Legion agents see the same KB. Leave blank to skip.
SUPER_AGENT_BASE_URL=https://super-agent-production.up.railway.app

# ── n8n magic-link webhook (shared with inspiring-cat) ───────────
N8N_MAGIC_LINK_WEBHOOK=

# ── Rate-limit defaults ──────────────────────────────────────────
CLAUDE_B_RPM=40
KIMI_RPM=60
GEMINI_B_RPM=15
HF_RPM=1000
