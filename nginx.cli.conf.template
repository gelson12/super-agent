events {
    worker_connections 4096;
    use epoll;
    multi_accept on;
}

http {
    include            /etc/nginx/mime.types;
    default_type       application/octet-stream;
    sendfile           on;
    tcp_nopush         on;
    tcp_nodelay        on;

    keepalive_timeout  300s;
    keepalive_requests 10000;

    client_max_body_size 256m;
    client_body_timeout  300s;
    client_header_timeout 60s;

    proxy_buffering    off;
    proxy_buffer_size  4k;

    server {
        listen ${PORT};

        # ── CLI Worker task API ────────────────────────────────────────────────
        # These exact paths go to the FastAPI task queue (port 8003 internal)
        location = /health {
            proxy_pass              http://127.0.0.1:8003;
            proxy_http_version      1.1;
            proxy_set_header Host   $host;
        }

        location = /health/detailed {
            proxy_pass              http://127.0.0.1:8003;
            proxy_http_version      1.1;
            proxy_set_header Host   $host;
        }
        location /tasks {
            proxy_pass              http://127.0.0.1:8003;
            proxy_http_version      1.1;
            proxy_set_header Host   $host;
            proxy_read_timeout      3600s;
            proxy_send_timeout      3600s;
            proxy_connect_timeout   10s;
        }
        location /docs {
            proxy_pass              http://127.0.0.1:8003;
            proxy_http_version      1.1;
            proxy_set_header Host   $host;
        }
        location /openapi.json {
            proxy_pass              http://127.0.0.1:8003;
            proxy_http_version      1.1;
        }
        location /webhook/ {
            proxy_pass              http://127.0.0.1:8003;
            proxy_http_version      1.1;
            proxy_set_header Host   $host;
            proxy_read_timeout      3600s;
            proxy_send_timeout      3600s;
            proxy_connect_timeout   10s;
        }
        location /auth/ {
            proxy_pass              http://127.0.0.1:8003;
            proxy_http_version      1.1;
            proxy_set_header Host   $host;
            proxy_read_timeout      60s;
            proxy_send_timeout      60s;
            proxy_connect_timeout   10s;
        }
        location /memory/ {
            proxy_pass              http://127.0.0.1:8003/memory/;
            # Routes: /memory/ingest /memory/export /memory/stats
            #         /memory/search /memory/prune /memory/health /memory/n8n-ingest
            proxy_http_version      1.1;
            proxy_set_header Host                $host;
            proxy_set_header X-Real-IP           $remote_addr;
            proxy_set_header X-Forwarded-For     $proxy_add_x_forwarded_for;
            proxy_set_header X-Memory-Secret     $http_x_memory_secret;
            proxy_buffering         off;
            proxy_read_timeout      60s;
            proxy_send_timeout      60s;
            proxy_connect_timeout   5s;
        }

        # ── Suppress favicon 404 noise ────────────────────────────────────────
        location = /favicon.ico {
            return 204;
            access_log off;
            log_not_found off;
        }

        # ── VS Code (code-server) — everything else ────────────────────────────
        #
        # WebSocket upgrade is mandatory for code-server terminals + extension host.
        # proxy_read_timeout 24h keeps VS Code sessions alive indefinitely.
        # proxy_buffering off prevents terminal freezing and SSE drops.
        #
        location / {
            proxy_pass              http://127.0.0.1:3001/;
            proxy_http_version      1.1;

            proxy_set_header Upgrade             $http_upgrade;
            proxy_set_header Connection          "upgrade";
            proxy_set_header Host                $host;
            proxy_set_header X-Real-IP           $remote_addr;
            proxy_set_header X-Forwarded-For     $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto   $scheme;

            proxy_buffering         off;
            proxy_request_buffering off;

            proxy_read_timeout      86400s;
            proxy_send_timeout      86400s;
            proxy_connect_timeout   10s;
        }
    }
}
